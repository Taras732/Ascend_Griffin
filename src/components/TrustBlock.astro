---
const isUk = Astro.currentLocale === "uk";

const copy = isUk
  ? {
      eyebrow: "Чому це працює",
      careerProof: "Бачу приховані ризики у ваших IT-проєктах і перекладаю складне в упевнені рішення — від першої ідеї до працюючого результату.",
      pillars: [
        { num: "01", title: "У ваших інтересах", text: "Мої рекомендації служать одному — вашому результату. Людей, рішення й підрядників підбираю під ваш проєкт і його цілі." },
        { num: "02", title: "Технічна глибина", text: "Розумію архітектуру й читаю пропозиції вендорів наскрізь — бачу те, що написано між рядків." },
        { num: "03", title: "Ясність наперед", text: "Обсяг і ціна узгоджені до старту, кожне рішення — письмово. Ви завжди розумієте, що і чому відбувається." },
      ],
    }
  : {
      eyebrow: "Why this works",
      careerProof: "I see the hidden risks in your IT projects and turn complexity into confident decisions — from the first idea to a working result.",
      pillars: [
        { num: "01", title: "In your interest", text: "My recommendations serve one thing — your result. People, decisions, and vendors are chosen to fit your project and its goals." },
        { num: "02", title: "Technical depth", text: "I understand architecture and read vendor proposals end to end — I see what's written between the lines." },
        { num: "03", title: "Clarity upfront", text: "Scope and price are agreed before we start, every decision in writing. You always understand what's happening and why." },
      ],
    };
---

<section class="trust-block">
  <div class="trust-shell">
    <p class="trust-eyebrow">{copy.eyebrow}</p>
    <p class="trust-proof">{copy.careerProof}</p>

    <div class="trust-grid">
      {copy.pillars.map((p) => (
        <div class="trust-card">
          <div class="trust-pillar-num">{p.num}</div>
          <div class="trust-pillar-title">{p.title}</div>
          <div class="trust-pillar-text">{p.text}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .trust-block {
    padding: 48px 0;
    background: var(--bg-1);
    border-top: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    margin: 0;
  }
  .trust-shell {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 var(--gutter);
  }
  @media (max-width: 720px) {
    .trust-shell { padding: 0 var(--gutter-sm); }
  }
  .trust-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    margin: 0 0 12px;
    font-weight: 600;
  }
  .trust-proof {
    font-family: var(--font-display);
    font-size: clamp(18px, 2.2vw, 22px);
    color: var(--text-1);
    margin: 0 0 28px;
    line-height: 1.4;
    font-weight: 600;
    max-width: 56ch;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
    margin-bottom: 24px;
  }
  @media (max-width: 720px) {
    .trust-grid { grid-template-columns: 1fr; gap: 12px; }
  }
  .trust-card {
    background: var(--bg-0);
    padding: 20px;
    border-radius: 8px;
    border: 1px solid var(--border-1);
    min-width: 0;
    position: relative;
    overflow: hidden;
    transition: all var(--dur-base) var(--ease);
  }
  .trust-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(300px circle at var(--mouse-x, 0px) var(--mouse-y, 0px), var(--mouse-glow), transparent 45%);
    opacity: 0;
    transition: opacity 0.35s ease;
    z-index: 1;
    pointer-events: none;
  }
  .trust-card:hover::before {
    opacity: 1;
  }
  .trust-card > * {
    position: relative;
    z-index: 2;
  }
  .trust-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .trust-stat {
    font-family: var(--font-display);
    font-size: 32px;
    color: var(--editorial);
    line-height: 1;
    margin-bottom: 8px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .trust-label,
  .trust-meta-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .trust-meta-value {
    font-size: 14px;
    color: var(--text-1);
    line-height: 1.45;
    font-weight: 500;
    word-wrap: break-word;
  }
  .trust-pillar-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-pressed);
    font-weight: 700;
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .trust-pillar-title {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--text-1);
    font-weight: 700;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
  }
  .trust-pillar-text {
    font-size: 14px;
    color: var(--text-2);
    line-height: 1.55;
  }
  .trust-note {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
    line-height: 1.55;
    max-width: 70ch;
    margin: 0;
    font-style: italic;
  }
</style>
