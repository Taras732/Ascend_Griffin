---
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const localePrefix = isUk ? "/uk" : "";
const c = tr.consent;
---

<div
  id="ag-consent"
  class="consent"
  data-state="hidden"
  data-stage="main"
  role="dialog"
  aria-labelledby="ag-consent-title"
  aria-describedby="ag-consent-body"
  aria-hidden="true"
>
  <div class="consent-card">
    {/* Stage 1 — main banner */}
    <div class="consent-stage consent-stage-main" data-stage-panel="main">
      <p class="consent-eyebrow">Cookies</p>
      <h2 id="ag-consent-title">{c.title}</h2>
      <p id="ag-consent-body" class="consent-body">{c.body}</p>
      <p class="consent-link">
        <a href={`${localePrefix}/privacy`}>{c.policyLink} →</a>
      </p>

      <div class="consent-actions">
        <button type="button" class="consent-btn consent-btn-primary" data-consent-action="accept">
          {c.btnAccept}
        </button>
        <button type="button" class="consent-btn consent-btn-secondary" data-consent-action="reject">
          {c.btnReject}
        </button>
        <button type="button" class="consent-btn-text" data-consent-action="customize">
          {c.btnCustomize}
        </button>
      </div>
    </div>

    {/* Stage 2 — customize panel */}
    <div class="consent-stage consent-stage-custom" data-stage-panel="custom" hidden>
      <p class="consent-eyebrow">{c.btnCustomize}</p>
      <h2>{c.manageTitle}</h2>
      <p class="consent-body">{c.manageBody}</p>

      <ul class="consent-cats">
        <li class="consent-cat">
          <div class="consent-cat-head">
            <span class="consent-cat-name">{c.catEssentialTitle}</span>
            <label class="consent-toggle consent-toggle-locked" aria-label={c.catEssentialTitle}>
              <input type="checkbox" checked disabled />
              <span class="consent-toggle-track" aria-hidden="true"></span>
            </label>
          </div>
          <p class="consent-cat-body">{c.catEssentialBody}</p>
        </li>

        <li class="consent-cat">
          <div class="consent-cat-head">
            <span class="consent-cat-name">{c.catAnalyticsTitle}</span>
            <label class="consent-toggle" aria-label={c.catAnalyticsTitle}>
              <input type="checkbox" data-consent-cat="analytics" />
              <span class="consent-toggle-track" aria-hidden="true"></span>
            </label>
          </div>
          <p class="consent-cat-body">{c.catAnalyticsBody}</p>
        </li>

        <li class="consent-cat">
          <div class="consent-cat-head">
            <span class="consent-cat-name">{c.catFunctionalTitle}</span>
            <label class="consent-toggle" aria-label={c.catFunctionalTitle}>
              <input type="checkbox" data-consent-cat="functional" checked />
              <span class="consent-toggle-track" aria-hidden="true"></span>
            </label>
          </div>
          <p class="consent-cat-body">{c.catFunctionalBody}</p>
        </li>
      </ul>

      <div class="consent-actions consent-actions-custom">
        <button type="button" class="consent-btn consent-btn-primary" data-consent-action="save">
          {c.btnSave}
        </button>
        <button type="button" class="consent-btn-text" data-consent-action="back">
          ← {c.btnBack}
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .consent {
    position: fixed;
    left: 24px;
    bottom: 24px;
    z-index: 9000;
    max-width: 460px;
    width: calc(100% - 48px);
    transform: translateY(calc(100% + 32px));
    opacity: 0;
    pointer-events: none;
    transition:
      transform var(--dur-base) var(--ease),
      opacity var(--dur-base) var(--ease);
  }
  .consent[data-state="visible"] {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
  .consent-card {
    background: var(--bg-0);
    border: 1px solid var(--border-2);
    border-radius: 4px;
    padding: 24px;
    box-shadow: var(--shadow-lg);
  }
  .consent-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    margin: 0 0 12px;
  }
  .consent h2 {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text-1);
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .consent-body {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0 0 14px;
  }
  .consent-link {
    margin: 0 0 18px;
    font-size: 13px;
  }
  .consent-link a {
    color: var(--accent-pressed);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease);
  }
  .consent-link a:hover { color: var(--accent); }

  .consent-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
  }
  .consent-actions-custom { margin-top: 20px; }

  .consent-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 11px 18px;
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: -0.005em;
    border-radius: 2px;
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--dur-base) var(--ease);
    white-space: nowrap;
  }
  .consent-btn-primary {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .consent-btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }
  .consent-btn-secondary {
    background: transparent;
    color: var(--text-1);
    border-color: var(--border-3);
  }
  .consent-btn-secondary:hover {
    border-color: var(--text-1);
    background: var(--bg-1);
  }
  .consent-btn-text {
    background: transparent;
    border: 0;
    padding: 8px 4px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease);
  }
  .consent-btn-text:hover { color: var(--text-1); }

  /* Customize panel */
  .consent-cats {
    list-style: none;
    margin: 16px 0 0;
    padding: 0;
    border-top: 1px solid var(--border-1);
  }
  .consent-cat {
    padding: 14px 0;
    border-bottom: 1px solid var(--border-1);
  }
  .consent-cat-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 6px;
  }
  .consent-cat-name {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text-1);
    letter-spacing: -0.005em;
  }
  .consent-cat-body {
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-3);
    margin: 0;
  }

  /* Toggle */
  .consent-toggle {
    position: relative;
    display: inline-block;
    width: 36px;
    height: 20px;
    flex-shrink: 0;
    cursor: pointer;
  }
  .consent-toggle input {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    cursor: pointer;
    margin: 0;
  }
  .consent-toggle-track {
    position: absolute;
    inset: 0;
    background: var(--bg-3);
    border-radius: 20px;
    transition: background var(--dur-base) var(--ease);
  }
  .consent-toggle-track::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    background: var(--bg-0);
    border-radius: 50%;
    transition: transform var(--dur-base) var(--ease);
    box-shadow: var(--shadow-sm);
  }
  .consent-toggle input:checked ~ .consent-toggle-track { background: var(--accent); }
  .consent-toggle input:checked ~ .consent-toggle-track::after { transform: translateX(16px); }
  .consent-toggle input:focus-visible ~ .consent-toggle-track {
    box-shadow: var(--focus-ring);
  }
  .consent-toggle-locked { cursor: not-allowed; opacity: 0.7; }
  .consent-toggle-locked input { cursor: not-allowed; }

  @media (max-width: 520px) {
    .consent {
      left: 12px;
      right: 12px;
      bottom: 12px;
      width: auto;
      max-width: none;
    }
    .consent-card { padding: 20px; }
    .consent h2 { font-size: 17px; }
    .consent-actions { flex-direction: column; align-items: stretch; }
    .consent-btn { width: 100%; }
    .consent-btn-text { width: 100%; text-align: center; }
  }
</style>
