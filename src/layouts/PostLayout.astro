---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  lang: "en" | "uk";
  tags?: string[];
  ogImage?: string;
}

const { title, description, pubDate, updatedDate, lang, tags = [] } = Astro.props;
const isUk = lang === "uk";
const formattedPubDate = pubDate.toLocaleDateString(isUk ? "uk-UA" : "en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString(isUk ? "uk-UA" : "en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;
const backToBlog = isUk ? "/uk/blog/" : "/blog/";
const backLabel = isUk ? "← Усі статті" : "← All posts";
const updatedLabel = isUk ? "Оновлено" : "Updated";
const tagsLabel = isUk ? "Теми" : "Tags";
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="page-main">
    <article class="post">
      <div class="content-shell">
        <a class="post-back" href={backToBlog}>{backLabel}</a>

        <header class="post-header">
          <h1 class="post-h1">{title}</h1>
          <p class="post-meta">
            <time datetime={pubDate.toISOString()}>{formattedPubDate}</time>
            {formattedUpdated && (
              <>
                <span class="dot">·</span>
                <span>{updatedLabel}: {formattedUpdated}</span>
              </>
            )}
          </p>
          {description && <p class="post-lede">{description}</p>}
        </header>

        <div class="post-body content-section">
          <slot />
        </div>

        {tags.length > 0 && (
          <div class="post-tags">
            <span class="post-tags-label">{tagsLabel}:</span>
            {tags.map((tag) => (
              <span class="post-tag">#{tag}</span>
            ))}
          </div>
        )}

        <div class="post-cta">
          <h3>
            {isUk
              ? "Маєте подібний проект і хочете обговорити?"
              : "Working on something similar? Let's talk."}
          </h3>
          <p>
            {isUk
              ? "30-хвилинна розмова — без презентацій, без обов'язків."
              : "30-minute Discovery Call — no slides, no obligation."}
          </p>
          <a
            href="#book"
            class="post-cta-btn"
            data-modal="booking"
            data-subject="discovery-call"
            data-source="blog-post"
          >
            {isUk ? "Discovery Call →" : "Book Discovery Call →"}
          </a>
        </div>
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<style>
  .post {
    padding: 64px 0 96px;
  }
  @media (max-width: 720px) {
    .post { padding: 40px 0 64px; }
  }
  .post-back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--text-3);
    text-decoration: none;
    margin-bottom: 32px;
    transition: color var(--dur-fast) var(--ease);
  }
  .post-back:hover { color: var(--accent-pressed); }

  .post-header { margin-bottom: 48px; }
  .post-h1 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4.5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--text-1);
    margin: 0 0 16px;
    font-weight: 700;
  }
  .post-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
    letter-spacing: 0.02em;
    margin: 0 0 24px;
  }
  .post-meta .dot { margin: 0 8px; }
  .post-lede {
    font-size: 20px;
    line-height: 1.5;
    color: var(--text-2);
    margin: 0;
    max-width: 60ch;
  }

  .post-body { margin-bottom: 56px; }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    padding: 24px 0;
    border-top: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    margin-bottom: 48px;
  }
  .post-tags-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-right: 4px;
  }
  .post-tag {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-2);
    background: var(--bg-1);
    padding: 4px 10px;
    border-radius: 2px;
  }

  .post-cta {
    background: var(--bg-ink);
    color: var(--text-on-ink);
    padding: 40px;
    border-radius: 2px;
    text-align: center;
  }
  .post-cta h3 {
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--text-on-ink);
    margin: 0 0 12px;
    line-height: 1.3;
    font-weight: 600;
  }
  .post-cta p {
    color: var(--text-on-ink-muted);
    margin: 0 0 24px;
    font-size: 15px;
  }
  .post-cta-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--accent-ink);
    padding: 14px 28px;
    text-decoration: none;
    font-weight: 600;
    border-radius: 2px;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: background var(--dur-fast) var(--ease);
  }
  .post-cta-btn:hover { background: var(--accent-hover); }
</style>
