---
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const stepsLabel = Astro.currentLocale === "uk" ? "Етапи" : "Steps";
const resultLabel = Astro.currentLocale === "uk" ? "Результат:" : "Result:";
---

<section class="section why-section" id="why">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">{tr.whySection.num}</div>
      <div class="section-head-body">
        <h2 set:html={tr.whySection.h2Html} />
        <p class="lede">
          {tr.whySection.lede}
        </p>
      </div>
    </div>

    <div class="why-grid">
      {tr.pillars.map((p) => (
        <article class="why-item">
          <div class="why-num">{p.num}</div>
          <h3>{p.title}</h3>
          <p class="why-desc">{p.description}</p>
          <div class="why-steps">
            <div class="why-label">{stepsLabel}</div>
            <ol>
              {p.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </div>
          <div class="why-result">
            <span class="why-result-label">{resultLabel}</span> {p.result}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-1);
    border-left: 1px solid var(--border-1);
  }
  .why-item {
    padding: 40px 28px 32px;
    border-right: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    background: var(--bg-0);
    display: flex;
    flex-direction: column;
  }
  .why-num {
    font-family: var(--font-mono);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--editorial);
    line-height: 1;
    margin-bottom: 20px;
    font-variant-numeric: tabular-nums;
  }
  .why-item h3 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.35;
    color: var(--text-1);
    margin: 0 0 16px;
    min-height: 74px;
  }
  .why-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 22px;
  }
  .why-steps {
    padding-top: 18px;
    border-top: 1px solid var(--border-1);
    margin-bottom: 20px;
  }
  .why-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 12px;
  }
  .why-steps ol {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
  }
  .why-steps li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 10px;
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--text-2);
    counter-increment: step;
  }
  .why-steps li:last-child {
    margin-bottom: 0;
  }
  .why-steps li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 1px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--editorial);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  .why-result {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border-1);
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    line-height: 1.55;
  }
  .why-result-label {
    color: var(--accent-pressed);
    font-weight: 600;
    margin-right: 4px;
  }
  @media (max-width: 860px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
