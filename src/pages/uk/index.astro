---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import TrustBlock from "../../components/TrustBlock.astro";
import FoundingCTA from "../../components/FoundingCTA.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "uk" && !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />

    {/* ── Сервіси ─────────────────────────────────────────────── */}
    <section class="home-section">
      <div class="home-shell">
        <p class="home-eyebrow">Формати співпраці</p>
        <h2 class="home-h2">Три способи <em>розв'язати завдання</em>.</h2>
        <p class="home-lede">
          Залежно від того, на якій ви стадії і що потрібно зараз — обираємо формат, який реально підходить вашій ситуації.
        </p>

        <div class="services-grid">
          <a href="/uk/ai-readiness-audit/" class="service-card">
            <div class="service-card-num">01</div>
            <h3 class="service-card-title">Аудит AI-готовності</h3>
            <p class="service-card-price">від $1,000 · 5-14 днів</p>
            <p class="service-card-desc">
              Незалежна оцінка vibe-coded прототипу, пропозиції від вендора або AI-функції, що перестала працювати. Перед тим, як вкладати більше — структуроване читання.
            </p>
            <span class="service-card-link">Дізнатись більше →</span>
          </a>

          <article class="service-card service-card-soon">
            <div class="service-card-num">02</div>
            <h3 class="service-card-title">Дослідження</h3>
            <p class="service-card-price">від $4,000 · 2-8 тижнів</p>
            <p class="service-card-desc">
              Discovery Sprint для нетехнічних засновників: від ідеї до повного продуктового брифа, оцінки бюджету і списку правильних вендорів.
            </p>
            <span class="service-card-soon-tag">Окрема сторінка — скоро</span>
          </article>

          <a href="/uk/project-rescue/" class="service-card">
            <div class="service-card-num">03</div>
            <h3 class="service-card-title">Рятування проєкту</h3>
            <p class="service-card-price">від $2,500/міс · retainer</p>
            <p class="service-card-desc">
              Проект горить бюджетом, вендор зник, швидкість впала. Структуроване рятування від того, чий єдиний інтерес — ваш результат.
            </p>
            <span class="service-card-link">Дізнатись більше →</span>
          </a>
        </div>
      </div>
    </section>

    <TrustBlock />

    {/* ── Про мене teaser ─────────────────────────────────────── */}
    <section class="home-section home-section-bg">
      <div class="home-shell">
        <p class="home-eyebrow">Хто я</p>
        <h2 class="home-h2">Я бачу <em>підводні камені</em> заздалегідь.</h2>

        <div class="prose">
          <p>Я — Тарас Смалюх, CEO і CPO TreximAI (B2B AI-платформа логістики), засновник Ascend Griffin. 8 років бізнес-аналізу і продуктового менеджменту у AI-продуктах, логістиці, фінтеху та B2B SaaS.</p>
          <p>Моя сильна сторона — читати IT-проект як цілісну систему і бачити, де ризики, які інші не помічають. Скоуп, оцінки, продуктові рішення, технічні припущення, що звучать переконливо, але не тримають під тиском.</p>
          <p>Я не виступаю розробником у ваших проектах — але добре розумію архітектуру і працюю з сучасними AI-інструментами. Швидкий прототип чи невеликий функціонал, щоб перевірити гіпотезу, можу зібрати самостійно. А коли треба масштабувати — залучаємо технічну команду: вашу, якщо вже є, або підбираємо з мережі досвідчених фахівців, з якими я працював. Це звичайна модель того, як я працюю сьогодні.</p>
        </div>

        <a href="/uk/about/" class="link-arrow">Дізнатись більше про мене →</a>
      </div>
    </section>

    {/* ── Як це працює teaser ──────────────────────────────────── */}
    <section class="home-section">
      <div class="home-shell">
        <p class="home-eyebrow">Як це працює</p>
        <h2 class="home-h2">П'ять принципів, <em>жодних сюрпризів</em>.</h2>
        <p class="home-lede">
          Це контракт перед контрактом. Кожна співпраця — Аудит, Дослідження, Супровід — йде по цих п'яти правилах. Якщо хоч одне — dealbreaker, краще нам обом дізнатися зараз.
        </p>

        <ul class="principles-list">
          <li><span class="principle-num">01</span><span>Я завжди на вашому боці — без прихованих угод з вендорами.</span></li>
          <li><span class="principle-num">02</span><span>Ціна фіксована до старту. Жодних "ой, це коштуватиме більше".</span></li>
          <li><span class="principle-num">03</span><span>Discovery — завжди першим. Якщо не підходжу — скажу прямо.</span></li>
          <li><span class="principle-num">04</span><span>Залишаю задокументований слід — кожне рішення у тексті.</span></li>
          <li><span class="principle-num">05</span><span>Робота по плану, а не на час. Без роботи заради роботи.</span></li>
        </ul>

        <a href="/uk/how-i-work/" class="link-arrow">Детальніше про принципи →</a>
      </div>
    </section>

    {/* ── Блог teaser ─────────────────────────────────────────── */}
    {latestPosts.length > 0 && (
      <section class="home-section home-section-bg">
        <div class="home-shell">
          <p class="home-eyebrow">З блогу</p>
          <h2 class="home-h2">Думки і нотатки.</h2>
          <p class="home-lede">
            Про IT-проєкти, AI-інструменти та інші практики, якими я користуюсь у роботі.
          </p>

          <div class="blog-teaser-grid">
            {latestPosts.map((post) => (
              <BlogCard
                href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="uk"
                tags={post.data.tags}
              />
            ))}
          </div>

          <a href="/uk/blog/" class="link-arrow">Усі статті →</a>
        </div>
      </section>
    )}

    <FoundingCTA service="discovery" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .home-shell { max-width: 1120px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .home-shell { padding: 0 var(--gutter-sm); } }

  .home-section { padding: 80px 0; border-top: 1px solid var(--border-1); }
  @media (max-width: 720px) { .home-section { padding: 56px 0; } }
  .home-section-bg { background: var(--bg-1); }

  .home-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-pressed); margin: 0 0 16px; font-weight: 600; }
  .home-h2 { font-family: var(--font-display); font-size: clamp(32px, 4vw, 44px); line-height: 1.1; letter-spacing: -0.02em; color: var(--text-1); margin: 0 0 20px; font-weight: 700; max-width: 22ch; }
  .home-h2 em { font-style: italic; color: var(--editorial); }
  .home-lede { font-size: 18px; line-height: 1.6; color: var(--text-2); margin: 0 0 40px; max-width: 60ch; }

  .services-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 20px; margin-top: 8px; }
  @media (max-width: 900px) { .services-grid { grid-template-columns: 1fr; } }
  .service-card { background: var(--bg-0); border: 1px solid var(--border-1); border-radius: 4px; padding: 32px 28px; text-decoration: none; color: inherit; transition: all var(--dur-base) var(--ease); display: flex; flex-direction: column; gap: 10px; min-height: 280px; }
  .service-card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .service-card-soon { background: var(--bg-2); cursor: default; opacity: 0.85; }
  .service-card-soon:hover { transform: none; border-color: var(--border-1); box-shadow: none; }
  .service-card-num { font-family: var(--font-mono); font-size: 12px; color: var(--accent-pressed); font-weight: 700; letter-spacing: 0.04em; margin-bottom: 4px; }
  .service-card-title { font-family: var(--font-display); font-size: 22px; line-height: 1.25; letter-spacing: -0.015em; color: var(--text-1); margin: 0; font-weight: 700; }
  .service-card-price { font-family: var(--font-mono); font-size: 12px; color: var(--text-3); margin: 0 0 8px; letter-spacing: 0.02em; }
  .service-card-desc { font-size: 15px; line-height: 1.55; color: var(--text-2); margin: 0; flex: 1; }
  .service-card-link { font-family: var(--font-mono); font-size: 12px; color: var(--accent-pressed); letter-spacing: 0.04em; font-weight: 600; margin-top: 8px; }
  .service-card-soon-tag { font-family: var(--font-mono); font-size: 11px; color: var(--text-4); letter-spacing: 0.04em; margin-top: 8px; font-style: italic; }

  .prose p { font-size: 17px; line-height: 1.7; color: var(--text-2); margin: 0 0 18px; max-width: 65ch; }
  .prose p:last-child { margin-bottom: 0; }
  .prose p strong { color: var(--text-1); font-weight: 700; }

  .link-arrow { display: inline-block; margin-top: 32px; color: var(--accent-pressed); text-decoration: none; font-family: var(--font-mono); font-size: 13px; letter-spacing: 0.02em; font-weight: 600; border-bottom: 1px solid var(--accent); padding-bottom: 2px; transition: color var(--dur-fast) var(--ease); }
  .link-arrow:hover { color: var(--accent-hover); }

  .principles-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--text-1); }
  .principles-list li { display: grid; grid-template-columns: 56px 1fr; gap: 16px; padding: 18px 0; border-bottom: 1px solid var(--border-1); align-items: baseline; font-size: 17px; line-height: 1.5; color: var(--text-2); max-width: 70ch; }
  .principle-num { font-family: var(--font-mono); font-size: 16px; color: var(--accent-pressed); font-weight: 700; letter-spacing: 0.02em; line-height: 1.4; }

  .blog-teaser-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; margin-top: 8px; }
  @media (max-width: 720px) { .blog-teaser-grid { grid-template-columns: 1fr; } }
</style>
