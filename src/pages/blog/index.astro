---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "en" && !data.draft);

type Post = (typeof allPosts)[number];
const seriesGroups: Map<string, Post[]> = new Map();
const soloPosts: Post[] = [];

for (const post of allPosts) {
  if (post.data.series) {
    if (!seriesGroups.has(post.data.series)) seriesGroups.set(post.data.series, []);
    seriesGroups.get(post.data.series)!.push(post);
  } else {
    soloPosts.push(post);
  }
}

for (const [, posts] of seriesGroups) {
  posts.sort((a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999));
}
soloPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const seriesMeta: Record<string, { label: string; intro: string }> = {
  "obsidian-ai": {
    label: "Series · Obsidian + AI",
    intro:
      "How to build your own knowledge base on Obsidian with an AI assistant — from zero to working rhythm. Best read in order: each post builds on the previous.",
  },
};

const title = "Notes and thoughts | Ascend Griffin";
const description =
  "Practical notes on IT projects, AI tools, and other practices I use in my work.";
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="blog-index">
    <header class="blog-hero">
      <div class="blog-shell">
        <h1 class="blog-h1">Notes <em>and thoughts</em>.</h1>
        <p class="blog-lede">
          On IT projects, AI tools, and other practices I use in my work. In plain language.
        </p>

        <figure class="hero-media">
          <img src="/img/blog_cover.webp" alt="Editorial writing desk in warm evening light" loading="lazy" width="1344" height="768" />
        </figure>
      </div>
    </header>

    {seriesGroups.size > 0 && (
      <section class="series-cards-section">
        <div class="blog-shell">
          <p class="section-eyebrow">Series</p>
          <div class="series-cards-grid">
            {Array.from(seriesGroups.entries()).map(([seriesKey, posts], i) => (
              <a href={`/blog/series/${seriesKey}/`} class="series-card">
                <div class="series-card-num">{String(i + 1).padStart(2, "0")}</div>
                <h2 class="series-card-title">{(seriesMeta[seriesKey]?.label ?? seriesKey).replace(/^Series · /, "")}</h2>
                <p class="series-card-intro">{seriesMeta[seriesKey]?.intro ?? ""}</p>
                <div class="series-card-foot">
                  <span class="series-card-count">{posts.length} {posts.length === 1 ? "post" : "posts"}</span>
                  <span class="series-card-arrow" aria-hidden="true">→</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    {soloPosts.length > 0 && (
      <section class="solo-section">
        <div class="blog-shell">
          <p class="series-label">Standalone posts</p>
          <div class="blog-grid">
            {soloPosts.map((post) => (
              <BlogCard
                href={`/blog/${post.id.replace(/^en\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="en"
                tags={post.data.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    {seriesGroups.size === 0 && soloPosts.length === 0 && (
      <div class="blog-shell">
        <p class="blog-empty">
          English posts coming soon. Original write-up available on the <a href="/uk/blog/">Ukrainian edition</a>.
        </p>
      </div>
    )}
  </main>
  <Footer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      name: "Ascend Griffin — Notes and thoughts",
      url: "https://ascendgriffin.org/blog/",
      author: { "@type": "Person", name: "Taras Smaliukh" },
    })}
  />
</BaseLayout>

<style>
  .blog-index { background: radial-gradient(ellipse at top right, rgba(184, 135, 58, 0.04), transparent 50%), var(--bg-0); min-height: 100vh; }
  .blog-shell { max-width: 1120px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .blog-shell { padding: 0 var(--gutter-sm); } }
  .blog-hero { padding: 80px 0 40px; border-bottom: 1px solid var(--border-1); }
  @media (max-width: 720px) { .blog-hero { padding: 48px 0 28px; } }
  .blog-h1 { font-family: var(--font-display); font-size: clamp(40px, 5.5vw, 68px); line-height: 1.04; letter-spacing: -0.025em; color: var(--text-1); margin: 0 0 20px; font-weight: 700; max-width: 14ch; }
  .blog-h1 em { font-style: italic; color: var(--editorial); }
  .blog-lede { font-size: 19px; line-height: 1.6; color: var(--text-2); margin: 0 0 32px; max-width: 60ch; }

  .hero-media { margin: 8px 0 0; }
  .hero-media img { display: block; width: 100%; max-height: 340px; object-fit: cover; border-radius: 10px; border: 1px solid var(--border-1); box-shadow: var(--shadow-md); }
  @media (max-width: 720px) { .hero-media img { max-height: 220px; } }

  .series-cards-section { padding: 48px 0 40px; }
  .section-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-pressed); margin: 0 0 20px; font-weight: 700; }
  .series-cards-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 24px; }
  @media (max-width: 720px) { .series-cards-grid { grid-template-columns: 1fr; } }
  .series-card { background: var(--bg-1); border: 1px solid var(--border-1); border-radius: 4px; padding: 32px 28px; text-decoration: none; color: inherit; display: flex; flex-direction: column; gap: 12px; min-height: 220px; transition: all var(--dur-base) var(--ease); }
  .series-card:hover { border-color: var(--accent); background: var(--bg-0); transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .series-card:hover .series-card-arrow { color: var(--accent-pressed); transform: translateX(4px); }
  .series-card-num { font-family: var(--font-mono); font-size: 12px; color: var(--accent-pressed); font-weight: 700; letter-spacing: 0.06em; }
  .series-card-title { font-family: var(--font-display); font-size: clamp(22px, 2.6vw, 26px); line-height: 1.2; letter-spacing: -0.015em; color: var(--text-1); margin: 0; font-weight: 700; }
  .series-card-intro { font-size: 15px; line-height: 1.55; color: var(--text-2); margin: 0; flex: 1; }
  .series-card-foot { display: flex; align-items: baseline; justify-content: space-between; margin-top: 4px; }
  .series-card-count { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.04em; }
  .series-card-arrow { font-family: var(--font-mono); font-size: 18px; color: var(--text-4); transition: all var(--dur-fast) var(--ease); }

  .solo-section { padding: 56px 0; }
  @media (max-width: 720px) { .solo-section { padding: 40px 0; } }
  .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 20px; }
  @media (max-width: 720px) { .blog-grid { grid-template-columns: 1fr; } }
  .blog-empty { font-family: var(--font-mono); font-size: 14px; color: var(--text-3); padding: 40px 0; }
  .blog-empty a { color: var(--accent-pressed); text-decoration: underline; }
</style>
