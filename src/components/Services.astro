---
import { services } from "../data/services";
---

<section class="section services-section" id="services">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">04 · Формати</div>
      <div class="section-head-body">
        <h2>Три формати — залежно від <em>вашої стадії</em>.</h2>
        <p class="lede">
          Залежно від задачі і стадії проекту — можливі різні формати роботи. Кожен з чітким результатом і прозорим процесом.
        </p>
      </div>
    </div>

    <div class="services-grid">
      {services.map((s) => (
        <article class="service" id={`package-${s.id}`}>
          <div class="service-num">{s.num}</div>
          <h3 class="service-name">{s.name}</h3>
          <p class="service-hook">{s.hook}</p>
          <div class="service-price">{s.price}</div>
          <div class="service-price-note">{s.priceNote}</div>
          <ul class="service-features">
            {s.features.map((f) => <li>{f}</li>)}
          </ul>
          <a href="#book" data-modal="booking" data-subject={s.id} data-source={`service-${s.id}`} class="btn-secondary btn-full service-cta">
            {s.cta} <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-left: 1px solid var(--border-1);
    border-top: 1px solid var(--border-1);
  }
  .service {
    padding: 36px 28px 32px;
    background: var(--bg-0);
    border-right: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    display: flex;
    flex-direction: column;
    min-height: 500px;
    position: relative;
    transition: transform var(--dur-base) var(--ease), box-shadow var(--dur-base) var(--ease), background var(--dur-base) var(--ease);
  }
  /* Hover state — editorial accent reveals on hover (Brand Book v3 style) */
  .service:hover {
    transform: translateY(-3px);
    background: var(--bg-1);
    box-shadow: inset 0 3px 0 0 var(--accent), var(--shadow-md);
    z-index: 1;
  }
  .service:hover .service-num {
    color: var(--accent-pressed);
  }
  /* CTA button transforms to gold on card hover */
  .service-cta {
    transition: background var(--dur-base) var(--ease), color var(--dur-base) var(--ease), border-color var(--dur-base) var(--ease);
  }
  .service:hover .service-cta {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
  }
  .service:hover .service-cta:hover {
    background: var(--accent-hover);
    border-color: var(--accent-hover);
  }
  .service-num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    color: var(--text-3);
    margin-bottom: 16px;
  }
  .service-name {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--text-1);
    margin: 0 0 12px;
    line-height: 1.2;
  }
  .service-hook {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0 0 26px;
    min-height: 66px;
  }
  .service-price {
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-1);
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }
  .service-price-note {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-top: 8px;
    margin-bottom: 26px;
  }
  .service-features {
    list-style: none;
    padding: 0;
    margin: 0 0 28px;
    flex-grow: 1;
  }
  .service-features li {
    position: relative;
    padding-left: 22px;
    font-size: 13px;
    line-height: 1.55;
    color: var(--text-2);
    margin-bottom: 10px;
  }
  .service-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent-pressed);
    font-weight: 700;
    font-family: var(--font-mono);
  }
  @media (max-width: 960px) {
    .services-grid { grid-template-columns: 1fr; }
    .service { min-height: auto; }
  }
</style>
