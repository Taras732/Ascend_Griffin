---
import { site } from "../data/site";
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const localePrefix = isUk ? "/uk" : "";
---

<footer class="site-footer">
  <div class="site-container">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-brand">
          <span class="footer-brand-mark" role="img" aria-label="Ascend Griffin"></span>
          <span class="footer-brand-name">{site.name}</span>
        </div>
        <p class="footer-tag">{tr.site.footerTagline}</p>
        <p class="footer-by">— {site.founder}</p>
      </div>

      <div class="footer-col">
        <h5>{tr.site.footerConnectH}</h5>
        <ul>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
          <li><a href="#book" data-modal="booking" data-subject="discovery-call" data-source="footer">{isUk ? "Записатися на дзвінок" : "Book a call"}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h5>{tr.site.footerLegalH}</h5>
        <ul>
          <li><a href={`${localePrefix}/faq/`}>{isUk ? "Часті питання" : "FAQ"}</a></li>
          <li><a href={`${localePrefix}/privacy`}>{isUk ? "Приватність" : "Privacy"}</a></li>
          <li><a href={`${localePrefix}/impressum`}>Impressum</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {site.year} {site.name} · {site.domain}</span>
      <a class="footer-kuznya" href="https://kuznya.studio" target="_blank" rel="noopener">Зроблено за підтримки Кузні</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-1);
    border-top: 1px solid var(--border-1);
    padding: 40px 0 24px;
    font-size: 13px;
    color: var(--text-2);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 28px;
  }
  .footer-col h5 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 0 0 16px;
    font-weight: 600;
  }
  .footer-col ul { list-style: none; padding: 0; margin: 0; }
  .footer-col li { margin-bottom: 8px; }
  .footer-col a {
    color: var(--text-2);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-col a:hover { color: var(--accent-pressed); }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .footer-brand-mark {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background-image: url("/logo/ascend-griffin-full.png");
    background-repeat: no-repeat;
    background-color: #16140F;
    background-size: 63px;
    background-position: -16px -10px;
    box-shadow: 0 0 0 1px var(--accent-border);
  }
  .footer-brand-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-1);
  }
  .footer-tag {
    font-size: 13px;
    color: var(--text-3);
    max-width: 32ch;
    line-height: 1.55;
    margin: 0 0 10px;
  }
  .footer-by {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.02em;
    margin: 0;
  }
  .footer-bottom {
    border-top: 1px solid var(--border-1);
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-3);
  }
  .footer-kuznya {
    color: var(--text-3);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-kuznya::before {
    content: "";
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
  .footer-kuznya:hover { color: var(--editorial); }
  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
