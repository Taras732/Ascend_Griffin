---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Nav from "../../../../components/Nav.astro";
import Footer from "../../../../components/Footer.astro";
import FoundingCTA from "../../../../components/FoundingCTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const all = await getCollection("blog", ({ data }) => data.lang === "uk" && !data.draft && !!data.series);
  const groups = new Map<string, typeof all>();
  for (const post of all) {
    const k = post.data.series!;
    if (!groups.has(k)) groups.set(k, []);
    groups.get(k)!.push(post);
  }
  return Array.from(groups.entries()).map(([key, posts]) => {
    posts.sort((a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999));
    return { params: { key }, props: { posts, seriesKey: key } };
  });
}

const { posts, seriesKey } = Astro.props;

const seriesMeta: Record<string, { label: string; intro: string }> = {
  "obsidian-ai": {
    label: "Серія · Obsidian + AI",
    intro:
      "Як побудувати власну базу знань на Obsidian з підключенням AI — від нуля до робочого ритуалу. Читати краще за порядком: кожен пост опирається на попередній.",
  },
};

const meta = seriesMeta[seriesKey] ?? { label: seriesKey, intro: "" };
const title = `${meta.label} | Ascend Griffin`;
const description = meta.intro || "Серія статей на ascendgriffin.org";
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="series-page">
    <header class="series-hero">
      <div class="series-shell">
        <a class="series-back" href="/uk/blog/">← Усі серії</a>
        <p class="series-eyebrow">{meta.label}</p>
        <h1 class="series-h1">{meta.label.replace(/^Серія · /, "")}</h1>
        <p class="series-lede">{meta.intro}</p>
        <p class="series-count-line">
          {posts.length} {posts.length === 1 ? "стаття" : posts.length < 5 ? "статті" : "статей"} · читати краще за порядком
        </p>
      </div>
    </header>

    <section class="series-posts">
      <div class="series-shell">
        <ol class="series-list">
          {posts.map((post, i) => (
            <li class="series-item">
              <a href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`} class="series-link">
                <span class="series-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="series-content">
                  <span class="series-title">{post.data.title}</span>
                  <span class="series-desc">{post.data.description}</span>
                  <span class="series-meta">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString("uk-UA", { year: "numeric", month: "long", day: "numeric" })}
                    </time>
                    {post.data.readingTime && (
                      <>
                        <span class="dot">·</span>
                        <span>{post.data.readingTime}</span>
                      </>
                    )}
                  </span>
                </span>
                <span class="series-arrow" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <FoundingCTA service="discovery" />
  </main>
  <Footer />
</BaseLayout>

<style>
  .series-page { background: radial-gradient(ellipse at top right, rgba(184, 135, 58, 0.04), transparent 50%), var(--bg-0); min-height: 100vh; }
  .series-shell { max-width: 1120px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .series-shell { padding: 0 var(--gutter-sm); } }

  .series-hero { padding: 64px 0 40px; border-bottom: 1px solid var(--border-1); }
  @media (max-width: 720px) { .series-hero { padding: 40px 0 28px; } }
  .series-back { display: inline-block; font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.06em; color: var(--text-3); text-decoration: none; margin-bottom: 28px; transition: color var(--dur-fast) var(--ease); }
  .series-back:hover { color: var(--accent-pressed); }
  .series-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-pressed); margin: 0 0 18px; font-weight: 700; }
  .series-h1 { font-family: var(--font-display); font-size: clamp(40px, 5.5vw, 68px); line-height: 1.04; letter-spacing: -0.025em; color: var(--text-1); margin: 0 0 20px; font-weight: 700; max-width: 18ch; }
  .series-lede { font-size: 19px; line-height: 1.6; color: var(--text-2); margin: 0 0 16px; max-width: 60ch; }
  .series-count-line { font-family: var(--font-mono); font-size: 12px; color: var(--text-3); margin: 0; letter-spacing: 0.02em; }

  .series-posts { padding: 48px 0; }
  .series-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--text-1); }
  .series-item { margin: 0; }
  .series-link { display: grid; grid-template-columns: 64px 1fr 32px; gap: 20px; align-items: center; padding: 24px 0; border-bottom: 1px solid var(--border-1); text-decoration: none; color: inherit; transition: background var(--dur-fast) var(--ease); }
  .series-link:hover { background: var(--bg-1); }
  .series-link:hover .series-arrow { color: var(--accent-pressed); transform: translateX(4px); }
  @media (max-width: 720px) { .series-link { grid-template-columns: 40px 1fr 24px; gap: 14px; padding: 20px 0; } }
  .series-num { font-family: var(--font-mono); font-size: 24px; color: var(--accent-pressed); font-weight: 700; line-height: 1; letter-spacing: -0.02em; }
  .series-content { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .series-title { font-family: var(--font-display); font-size: clamp(18px, 2.2vw, 22px); line-height: 1.25; color: var(--text-1); font-weight: 700; letter-spacing: -0.01em; }
  .series-desc { font-size: 14px; line-height: 1.5; color: var(--text-2); max-width: 68ch; }
  .series-meta { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.02em; margin-top: 2px; }
  .series-meta .dot { margin: 0 6px; }
  .series-arrow { font-family: var(--font-mono); font-size: 18px; color: var(--text-4); text-align: right; transition: all var(--dur-fast) var(--ease); }
</style>
