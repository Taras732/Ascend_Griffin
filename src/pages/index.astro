---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import TrustBlock from "../components/TrustBlock.astro";
import FoundingCTA from "../components/FoundingCTA.astro";
import Footer from "../components/Footer.astro";
import BlogCard from "../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "en" && !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const services = [
  {
    num: "01",
    title: "AI Readiness Audit",
    price: "from $1,000 · 5-14 days",
    desc: "An independent assessment of a prototype, vendor proposal, or AI integration that stopped working. Before committing capital — a structured audit of risks and code.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>`,
    href: "/ai-readiness-audit/"
  },
  {
    num: "02",
    title: "Product Discovery",
    price: "from $4,000 · 2-8 weeks",
    desc: "Discovery Sprint for non-technical founders. We turn an idea into a tested concept, realistic budget, technical architecture, and a shortlist of vetted vendors.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`,
    href: "/idea-translator/"
  },
  {
    num: "03",
    title: "Project Recovery",
    price: "from $2,500/month · retainer",
    desc: "When a project loses momentum, vendor communication breaks down, or the budget is draining without results. Structural recovery with a clear path forward.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
    href: "/project-rescue/"
  },
  {
    num: "04",
    title: "Fractional Leadership",
    price: "from $2,500/month · retainer",
    desc: "Acting Product Owner or Advisor on your side. Reviewing vendor agreements, overseeing estimates, joining key demos, and keeping developers accountable.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
    href: "/how-i-work/"
  }
];
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />

    {/* ── Services ────────────────────────────────────────────── */}
    <section class="home-section" id="services">
      <div class="home-shell">
        <h2 class="section-title-caps">KEY SERVICES</h2>
        
        <div class="services-grid-redesign">
          {services.map((service) => (
            <a href={service.href} class="service-card-redesign glass-card">
              <div class="service-icon-badge" set:html={service.icon} />
              <h3 class="service-card-title-redesign">{service.title}</h3>
              <p class="service-card-price-redesign">{service.price}</p>
              <p class="service-card-desc-redesign">{service.desc}</p>
              <span class="service-card-link-redesign">Learn more →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <TrustBlock />

    {/* ── About teaser ─────────────────────────────────────────── */}
    <section class="home-section home-section-bg">
      <div class="home-shell">
        <h2 class="section-title-caps">WHO I AM</h2>
        <div class="prose-redesign">
          <p class="prose-lead">I see the hidden risks in IT projects before they become expensive mistakes.</p>
          <p>I'm Taras Smaliukh — CEO and CPO of TreximAI (a B2B AI logistics platform) and founder of Ascend Griffin. 8 years of business analysis and product ownership across AI products, logistics, fintech, and B2B SaaS.</p>
          <p>My strength is reading an IT project as a whole system and spotting the risks others miss. Scope, estimates, product decisions, technical assumptions that sound convincing but don't hold under pressure.</p>
          <p>I'm not the developer on your project — but I understand architecture well and work fluently with modern AI tools. When it needs to scale, we bring in a tech team — yours, if you already have one; or vetted specialists I've worked with before.</p>
        </div>
        <a href="/about/" class="link-arrow-redesign">More about me →</a>
      </div>
    </section>

    {/* ── How I work teaser ────────────────────────────────────── */}
    <section class="home-section">
      <div class="home-shell">
        <h2 class="section-title-caps">HOW I WORK</h2>
        <p class="home-lede-redesign">
          The contract before the contract. Every engagement — Audit, Discovery, Project Support — runs on these five rules.
        </p>

        <div class="principles-grid">
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">01</span>
            <h4>Always on your side</h4>
            <p>Recommendations serve your interests exclusively. No vendor kickbacks, no hidden agendas.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">02</span>
            <h4>Price fixed before start</h4>
            <p>No hourly billing. The price is agreed before work begins. No quiet budget adjustments.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">03</span>
            <h4>Discovery first</h4>
            <p>If I am not the right read for your specific situation — I will say so on our very first call.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">04</span>
            <h4>Documented trail</h4>
            <p>Every decision, recommendation, and estimate audit is delivered in writing for your records.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">05</span>
            <h4>Work to the plan</h4>
            <p>No work-for-the-sake-of-work. Success is measured by outcomes delivered, not hours spent.</p>
          </div>
        </div>

        <a href="/how-i-work/" class="link-arrow-redesign">More on the principles →</a>
      </div>
    </section>

    {/* ── Blog teaser ──────────────────────────────────────────── */}
    {latestPosts.length > 0 && (
      <section class="home-section home-section-bg">
        <div class="home-shell">
          <h2 class="section-title-caps">FROM THE BLOG</h2>
          <p class="home-lede-redesign">Notes and thoughts on IT projects, AI tools, and product practices.</p>

          <div class="blog-teaser-grid-redesign">
            {latestPosts.map((post) => (
              <BlogCard
                href={`/blog/${post.id.replace(/^en\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="en"
                tags={post.data.tags}
              />
            ))}
          </div>

          <a href="/blog/" class="link-arrow-redesign" style="margin-top: 40px;">All posts →</a>
        </div>
      </section>
    )}

    <FoundingCTA service="discovery" />
  </main>
  <Footer />

  <script is:inline>
    // Browser language redirect — only on first visit, only for root EN page
    (function () {
      try {
        var REDIRECTED_KEY = "ag_lang_redirect_done";
        if (sessionStorage.getItem(REDIRECTED_KEY)) return;
        var lang = (navigator.language || "en").toLowerCase();
        if (lang.indexOf("uk") === 0) {
          sessionStorage.setItem(REDIRECTED_KEY, "1");
          window.location.replace("/uk/");
        }
      } catch (e) {
        /* ignore */
      }
    })();
  </script>
</BaseLayout>

<style>
  .home-shell { max-width: var(--container); margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .home-shell { padding: 0 var(--gutter-sm); } }

  .home-section { padding: 100px 0; border-top: 1px solid var(--border-1); }
  @media (max-width: 720px) { .home-section { padding: 64px 0; } }
  .home-section-bg { background: var(--bg-1); }

  .section-title-caps {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 0 0 40px;
    font-weight: 700;
  }

  .home-lede-redesign {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 40px;
    max-width: 60ch;
  }

  /* 4-column Services Grid from Mockup */
  .services-grid-redesign {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 1024px) {
    .services-grid-redesign { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .services-grid-redesign { grid-template-columns: 1fr; }
  }

  .service-card-redesign {
    border-radius: 12px;
    padding: 32px 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    min-height: 320px;
    border: 1px solid var(--border-1);
  }
  .service-icon-badge {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent);
    color: var(--accent-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.18);
    transition: transform var(--dur-base) var(--ease), background-color var(--dur-base) var(--ease);
  }
  .service-card-redesign:hover .service-icon-badge {
    transform: scale(1.08) rotate(3deg);
    background: var(--accent-hover);
  }
  .service-card-title-redesign {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text-1);
    margin: 0 0 6px;
    font-weight: 700;
  }
  .service-card-price-redesign {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    margin: 0 0 16px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .service-card-desc-redesign {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0;
    flex: 1;
  }
  .service-card-link-redesign {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.04em;
    font-weight: 700;
    margin-top: 24px;
    text-transform: uppercase;
  }

  .prose-redesign p { font-size: 17px; line-height: 1.7; color: var(--text-2); margin: 0 0 18px; max-width: 65ch; }
  .prose-redesign p:last-child { margin-bottom: 0; }
  .prose-lead { font-size: 22px !important; font-weight: 600; color: var(--text-1); line-height: 1.4 !important; margin-bottom: 24px !important; }

  .link-arrow-redesign {
    display: inline-block;
    margin-top: 32px;
    color: var(--accent-pressed);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    font-weight: 700;
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
    transition: color var(--dur-fast) var(--ease);
    text-transform: uppercase;
  }
  .link-arrow-redesign:hover { color: var(--accent-hover); }

  /* 5 Principles Grid Redesign */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }
  @media (max-width: 1024px) {
    .principles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .principles-grid { grid-template-columns: 1fr; }
  }
  .principle-item {
    padding: 24px 20px;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .principle-num-redesign {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-pressed);
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .principle-item h4 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-1);
    margin: 0;
  }
  .principle-item p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-3);
    margin: 0;
  }

  .blog-teaser-grid-redesign {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  @media (max-width: 720px) { .blog-teaser-grid-redesign { grid-template-columns: 1fr; } }
</style>
