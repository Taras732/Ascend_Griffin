---
import { modes } from "../data/modes";
---

<section class="section mode-section" id="mode">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">05 · Режими</div>
      <div class="section-head-body">
        <h2>Advisor або <em>Full-Cycle</em>. Ви обираєте.</h2>
        <p class="lede">
          Одна практика — два modes. Choose однозначно: чи вам потрібен oversight
          вашої команди, чи ви хочете мою.
        </p>
      </div>
    </div>

    <div class="mode-grid">
      {modes.map((m) => (
        <div class="mode-col">
          <div class="mode-label">{m.label}</div>
          <h3>{m.title}</h3>
          <p class="mode-hook">{m.hook}</p>

          <ul class="mode-list fit">
            {m.fit.map((item) => <li>{item}</li>)}
          </ul>
          <ul class="mode-list nofit">
            {m.nofit.map((item) => <li>{item}</li>)}
          </ul>

          <a href={m.linkHref} class="mode-link">{m.linkText}</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .mode-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border: 1px solid var(--border-1);
  }
  .mode-col {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
  }
  .mode-col:first-child {
    border-right: 1px solid var(--border-1);
  }
  .mode-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    padding: 4px 10px;
    border: 1px solid var(--accent-border);
    align-self: flex-start;
    margin-bottom: 24px;
    background: var(--accent-subtle);
  }
  .mode-col h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 16px;
  }
  .mode-hook {
    font-size: 15px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0 0 28px;
  }
  .mode-list {
    list-style: none;
    padding: 0;
    margin: 0 0 18px;
  }
  .mode-list li {
    position: relative;
    padding-left: 22px;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-2);
    margin-bottom: 8px;
  }
  .mode-list.fit li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--accent-pressed);
    font-weight: 700;
    font-family: var(--font-mono);
  }
  .mode-list.nofit li {
    color: var(--text-3);
  }
  .mode-list.nofit li::before {
    content: "×";
    position: absolute;
    left: 0;
    color: var(--text-4);
    font-weight: 700;
    font-family: var(--font-mono);
  }
  .mode-link {
    margin-top: auto;
    padding-top: 20px;
    border-top: 1px solid var(--border-1);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--accent-pressed);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .mode-link:hover { color: var(--editorial); }
  @media (max-width: 720px) {
    .mode-grid { grid-template-columns: 1fr; }
    .mode-col:first-child {
      border-right: 0;
      border-bottom: 1px solid var(--border-1);
    }
  }
</style>
