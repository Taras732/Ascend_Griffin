---
import { site } from "../data/site";
import BookingModal from "../components/BookingModal.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import { t } from "../i18n/translations";
import "../styles/tokens.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** Text-heavy pages: hide the decorative griffin watermark for readability */
  plain?: boolean;
  /** Homepage: preload the hero portrait (the LCP image) */
  heroPreload?: boolean;
}

const tr = t(Astro.currentLocale);
const lang = Astro.currentLocale === "uk" ? "uk" : "en";
const { title = tr.site.seo.title, description = tr.site.seo.description, noindex = false, plain = false, heroPreload = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const altLocaleHref = lang === "uk" ? site.url + "/" : site.url + "/uk/";
const altLocaleCode = lang === "uk" ? "en" : "uk";
---

<!doctype html>
<html lang={lang} data-plain={plain ? "" : undefined}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={tr.site.seo.keywords} />
    <meta name="author" content={site.founder} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="alternate" hreflang={altLocaleCode} href={altLocaleHref} />
    <link rel="alternate" hreflang="x-default" href={site.url + "/"} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={tr.site.seo.locale} />
    <meta property="og:image" content={new URL(tr.site.seo.ogImage, site.url).toString()} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />

    {heroPreload && <link rel="preload" as="image" href="/taras.webp" fetchpriority="high" />}

    <!-- Favicon — golden griffin badge (our own griffin, crisp SVG + PNG fallback) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
    <meta name="theme-color" content="#16140F" />

    <!-- Fonts — loaded async so they don't block first paint (display=swap shows fallback first) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500&family=Manrope:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      />
    </noscript>

    <!-- Cinematic motion (reveal on scroll + hero entrance) — progressive, JS-driven -->
    <style is:global>
      .rv { opacity: 0; transform: translateY(22px); transition: opacity .8s var(--ease), transform .8s var(--ease); }
      .rv.in { opacity: 1; transform: none; }
      .rv-fade { opacity: 0; transition: opacity .9s var(--ease); }
      .rv-fade.in { opacity: 1; }
      .rv-1 { transition-delay: .07s } .rv-2 { transition-delay: .14s } .rv-3 { transition-delay: .21s }
      .rv-4 { transition-delay: .28s } .rv-5 { transition-delay: .35s }
      .hero-photo { will-change: transform; }
      .hero-photo img { transition: transform .6s var(--ease); }
      @media (prefers-reduced-motion: reduce) {
        .rv, .rv-fade { opacity: 1 !important; transform: none !important; transition: none !important; }
      }
    </style>

    <!-- JSON-LD: Person + ProfessionalService -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "Person",
            name: site.founder,
            url: site.url,
            sameAs: [site.linkedin],
            jobTitle: "IT-супровід від ідеї до результату",
            address: { "@type": "PostalAddress", addressLocality: "Lviv", addressCountry: "UA" },
          },
          {
            "@type": "ProfessionalService",
            name: site.name,
            url: site.url,
            founder: { "@type": "Person", name: site.founder },
            areaServed: ["Ukraine", "Poland", "Germany", "United Kingdom"],
            priceRange: "$$-$$$",
          },
        ],
      })}
    />

    {/* Google Consent Mode v2 — must run BEFORE GA4 loads. */}
    {/* Defaults to denied; user choice from localStorage applied immediately if present. */}
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = gtag;

        var stored = null;
        try {
          stored = JSON.parse(localStorage.getItem("ag_consent_v1") || "null");
        } catch (e) {
          /* ignore */
        }
        var analytics = stored && stored.v === 1 && stored.analytics === true ? "granted" : "denied";

        gtag("consent", "default", {
          ad_storage: "denied",
          ad_user_data: "denied",
          ad_personalization: "denied",
          analytics_storage: analytics,
          functionality_storage: "granted",
          security_storage: "granted",
          wait_for_update: 500,
        });

        gtag("js", new Date());
      })();
    </script>
  </head>
  <body>
    <slot />
    <BookingModal />
    <ConsentBanner />

    <!-- Cinematic motion controller — reveal on scroll, hero entrance, subtle portrait parallax -->
    <script is:inline>
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        function ready(fn) {
          if (document.readyState !== "loading") fn();
          else document.addEventListener("DOMContentLoaded", fn);
        }
        ready(function () {
          // HERO — staggered entrance on load
          var hero = document.querySelector(".hero");
          if (hero) {
            var items = hero.querySelectorAll(".hero-eyebrow, .hero-h1, .hero-lede, .hero-ctas, .hero-micro");
            items.forEach(function (el, i) { el.classList.add("rv"); if (i < 5) el.classList.add("rv-" + (i + 1)); });
            var photo = hero.querySelector(".hero-photo");
            if (photo) photo.classList.add("rv-fade");
            requestAnimationFrame(function () {
              requestAnimationFrame(function () {
                items.forEach(function (el) { el.classList.add("in"); });
                if (photo) photo.classList.add("in");
              });
            });
          }
          // SECTIONS below hero — reveal as they enter
          var io = new IntersectionObserver(function (es) {
            es.forEach(function (e) { if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); } });
          }, { threshold: 0.1, rootMargin: "0px 0px -6% 0px" });
          document.querySelectorAll("section").forEach(function (sec) {
            if (sec.classList.contains("hero")) return;
            sec.classList.add("rv");
            io.observe(sec);
          });
          // Cursor spotlight tracking for service cards and trust cards
          document.querySelectorAll(".service-card, .trust-card").forEach(function (card) {
            card.addEventListener("mousemove", function (e) {
              var rect = card.getBoundingClientRect();
              var x = e.clientX - rect.left;
              var y = e.clientY - rect.top;
              card.style.setProperty("--mouse-x", x + "px");
              card.style.setProperty("--mouse-y", y + "px");
            });
          });
          // PORTRAIT — subtle parallax + scale while hero in view
          var hp = document.querySelector(".hero-photo");
          var hpImg = hp && hp.querySelector("img");
          if (hp) {
            addEventListener("scroll", function () {
              var y = window.scrollY;
              if (y < window.innerHeight) {
                hp.style.transform = "translateY(" + (y * 0.05).toFixed(1) + "px)";
                if (hpImg) hpImg.style.transform = "scale(" + (1 + Math.min(y, 420) * 0.00014).toFixed(4) + ")";
              }
            }, { passive: true });
          }
        });
      })();
    </script>

    <!-- Anonymous visitor tracking (localStorage only — no cookies, no PII) -->
    <script is:inline>
      (function () {
        var V_KEY = "ag_visitor";
        var S_KEY = "ag_session";
        var now = Date.now();

        // Persistent visitor data
        var visitor = {};
        try {
          visitor = JSON.parse(localStorage.getItem(V_KEY) || "{}");
        } catch (e) {
          /* ignore */
        }
        if (!visitor.id) {
          visitor.id = "v_" + Math.random().toString(36).slice(2, 11) + Date.now().toString(36);
          visitor.firstVisit = now;
          visitor.totalVisits = 1;
        } else {
          visitor.totalVisits = (visitor.totalVisits || 0) + 1;
        }
        visitor.lastVisit = now;

        // UTM parameters (captured once on first visit with them)
        try {
          var params = new URLSearchParams(window.location.search);
          ["utm_source", "utm_medium", "utm_campaign", "utm_term", "utm_content"].forEach(function (k) {
            if (params.get(k) && !visitor[k]) visitor[k] = params.get(k);
          });
        } catch (e) {
          /* ignore */
        }

        try {
          localStorage.setItem(V_KEY, JSON.stringify(visitor));
        } catch (e) {
          /* ignore */
        }

        // Session data (clears when tab closes)
        var session = {};
        try {
          session = JSON.parse(sessionStorage.getItem(S_KEY) || "{}");
        } catch (e) {
          /* ignore */
        }
        if (!session.start) {
          session.start = now;
          session.pagesViewed = [window.location.pathname];
        } else {
          session.pagesViewed = session.pagesViewed || [];
          if (session.pagesViewed.indexOf(window.location.pathname) === -1) {
            session.pagesViewed.push(window.location.pathname);
          }
        }
        try {
          sessionStorage.setItem(S_KEY, JSON.stringify(session));
        } catch (e) {
          /* ignore */
        }

        // Expose for form submission
        window.__agVisitor = visitor;
        window.__agSession = session;
      })();
    </script>

    {/* Google Analytics 4 — gtag stub + Consent Mode default are set in <head>. */}
    {/* Loads only when ga4Id is set; respects analytics_storage consent state. */}
    {site.ga4Id && (
      <>
        <script
          async
          src={`https://www.googletagmanager.com/gtag/js?id=${site.ga4Id}`}
        ></script>
        <script is:inline define:vars={{ ga4Id: site.ga4Id }}>
          {`
            if (typeof window.gtag === 'function') {
              window.gtag('config', ga4Id, {
                anonymize_ip: true,
                cookie_flags: 'SameSite=Lax;Secure'
              });
            }
          `}
        </script>
      </>
    )}

    {/* Cloudflare Web Analytics — cookieless beacon (no consent gating needed). */}
    {site.cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${site.cfAnalyticsToken}"}`}
      ></script>
    )}

    {/* Consent banner controller — auto-initializes on DOM ready. */}
    <script>
      import "../scripts/consent";
    </script>
  </body>
</html>
