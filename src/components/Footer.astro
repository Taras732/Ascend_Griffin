---
import { site } from "../data/site";
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const localePrefix = isUk ? "/uk" : "";
---

<footer class="site-footer">
  <div class="site-container">
    <div class="footer-grid">
      <div class="footer-col">
        <div class="footer-brand">
          <span class="footer-brand-mark" role="img" aria-label="Ascend Griffin"></span>
          <span class="footer-brand-name">{site.name}</span>
        </div>
        <p class="footer-tag">{tr.site.footerTagline}</p>
        <p class="footer-by">— {site.founder}</p>
      </div>

      <div class="footer-col">
        <h5>{isUk ? "Контакти" : "Contact"}</h5>
        <ul>
          <li><a href={`tel:${site.phone}`}>{site.phoneFormatted}</a></li>
          <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        </ul>
        <div class="footer-icons">
          <a href={site.telegram} target="_blank" rel="noopener" aria-label="Telegram">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
          </a>
          <a href={site.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.06 2.87 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.12-.27-.2-.57-.35M12.05 21.78h-.01a9.87 9.87 0 01-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 01-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 012.89 6.99c0 5.45-4.44 9.88-9.89 9.88M20.52 3.45A11.78 11.78 0 0012.05 0C5.46 0 .1 5.36.1 11.89c0 2.1.55 4.14 1.59 5.95L0 24l6.34-1.65a11.88 11.88 0 005.7 1.45h.01c6.55 0 11.89-5.33 11.89-11.89 0-3.18-1.24-6.16-3.42-8.46"/></svg>
          </a>
          <a href={site.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
          </a>
        </div>
      </div>

      <div class="footer-col">
        <h5>{tr.site.footerLegalH}</h5>
        <ul>
          <li><a href={`${localePrefix}/privacy`}>{isUk ? "Приватність" : "Privacy"}</a></li>
          <li><a href={`${localePrefix}/terms`}>{isUk ? "Умови використання" : "Terms of use"}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {site.year} · {site.domain}</span>
      <a class="footer-kuznya" href="https://kuznya.studio" target="_blank" rel="noopener">Зроблено за підтримки Кузні</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-1);
    border-top: 1px solid var(--border-1);
    padding: 40px 0 24px;
    font-size: 13px;
    color: var(--text-2);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 28px;
  }
  .footer-col h5 {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-2);
    margin: 0 0 16px;
    font-weight: 600;
  }
  .footer-col ul { list-style: none; padding: 0; margin: 0; }
  .footer-col li { margin-bottom: 8px; }
  .footer-col a {
    color: var(--text-1);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-col a:hover { color: var(--editorial); }
  .footer-icons { display: flex; gap: 8px; margin-top: 14px; }
  .footer-icons a {
    width: 36px; height: 36px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--border-1);
    border-radius: 8px;
    color: var(--text-2);
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
  }
  .footer-icons a:hover { color: var(--editorial); border-color: var(--accent); transform: translateY(-2px); }
  .footer-icons svg { width: 18px; height: 18px; }
  .footer-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .footer-brand-mark {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background-image: url("/logo/ascend-griffin-full.png");
    background-repeat: no-repeat;
    background-color: #16140F;
    background-size: 63px;
    background-position: -16px -10px;
    box-shadow: 0 0 0 1px var(--accent-border);
  }
  .footer-brand-name {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-1);
  }
  .footer-tag {
    font-size: 13px;
    color: var(--text-2);
    max-width: 30ch;
    line-height: 1.55;
    margin: 0 0 10px;
  }
  .footer-by {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-2);
    letter-spacing: 0.02em;
    margin: 0;
  }
  .footer-bottom {
    border-top: 1px solid var(--border-1);
    padding-top: 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--text-2);
  }
  .footer-kuznya {
    color: var(--text-2);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-kuznya::before {
    content: "";
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.7;
  }
  .footer-kuznya:hover { color: var(--editorial); }
  @media (max-width: 860px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 520px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>
