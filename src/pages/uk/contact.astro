---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { site } from "../../data/site";

const title = "Контакти — Ascend Griffin";
const description =
  "Напишіть про ваш проєкт або ситуацію — відповім протягом дня. Перша розмова безкоштовна. Telegram, WhatsApp, email, Cal.com.";
---

<BaseLayout title={title} description={description} plain>
  <Nav />
  <main class="contact-page">
    <section class="contact-hero">
      <div class="contact-shell">
        <p class="contact-eyebrow">Зв'язок</p>
        <h1 class="contact-h1">Напишіть <em>мені</em>.</h1>
        <p class="contact-lede">
          Розкажіть коротко про ваш проєкт або ситуацію — відповім протягом дня. Перша розмова безкоштовна, без зобов'язань.
        </p>

        <div class="contact-grid">
          {/* ── Form ── */}
          <form
            class="contact-form"
            action="https://formsubmit.co/taras.smalych@gmail.com"
            method="POST"
          >
            <input type="hidden" name="_subject" value="Нова заявка з сайту Ascend Griffin" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://ascendgriffin.org/uk/" />
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

            <div class="cfield">
              <label for="nm">Ім'я</label>
              <input id="nm" name="name" type="text" placeholder="Як до вас звертатись" required />
            </div>

            <div class="cfield">
              <label for="ct">Telegram / WhatsApp / Email</label>
              <input id="ct" name="contact" type="text" placeholder="@username або email" required />
            </div>

            <div class="cfield">
              <label for="svc">Що вас цікавить?</label>
              <select id="svc" name="service" required>
                <option value="audit">Аудит — незалежна оцінка прототипу / пропозиції / AI-фічі</option>
                <option value="discovery">Discovery — від ідеї до продуктового брифа й бюджету</option>
                <option value="rescue">Порятунок проєкту — коли темп втрачено, а бюджет тане</option>
                <option value="intro">Просто познайомитись / порадитись</option>
              </select>
            </div>

            <div class="cfield">
              <label for="msg">Деталі</label>
              <textarea id="msg" name="message" placeholder="Опишіть коротко — яку задачу треба вирішити, на якій ви стадії..." required></textarea>
            </div>

            <button class="btn-primary btn-lg contact-submit" type="submit">Надіслати запит</button>
            <p class="contact-formnote">Дані йдуть лише мені на пошту. Жодного спаму.</p>
          </form>

          {/* ── Direct contacts ── */}
          <aside class="contact-side">
            <div class="contact-card">
              <h4>Прямі контакти</h4>
              <div class="contact-icons">
                <a href={`tel:${site.phone}`} aria-label="Зателефонувати">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1H8c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                </a>
                <a href={site.whatsapp} target="_blank" rel="noopener" aria-label="WhatsApp">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.47 14.38c-.3-.15-1.76-.87-2.03-.97-.27-.1-.47-.15-.67.15-.2.3-.77.96-.94 1.16-.17.2-.35.22-.64.08-.3-.15-1.26-.47-2.39-1.48-.88-.79-1.48-1.76-1.65-2.06-.17-.3-.02-.46.13-.6.13-.14.3-.35.45-.52.15-.17.2-.3.3-.5.1-.2.05-.37-.02-.52-.08-.15-.67-1.61-.92-2.21-.24-.58-.49-.5-.67-.51l-.57-.01c-.2 0-.52.07-.79.37-.27.3-1.04 1.02-1.04 2.48 0 1.46 1.06 2.87 1.21 3.07.15.2 2.1 3.2 5.08 4.49.71.3 1.26.49 1.69.62.71.23 1.36.2 1.87.12.57-.09 1.76-.72 2.01-1.41.25-.7.25-1.29.17-1.41-.07-.12-.27-.2-.57-.35M12.05 21.78h-.01a9.87 9.87 0 01-5.03-1.38l-.36-.21-3.74.98 1-3.65-.24-.37a9.86 9.86 0 01-1.51-5.26c0-5.45 4.44-9.88 9.89-9.88 2.64 0 5.12 1.03 6.99 2.9a9.82 9.82 0 012.89 6.99c0 5.45-4.44 9.88-9.89 9.88M20.52 3.45A11.78 11.78 0 0012.05 0C5.46 0 .1 5.36.1 11.89c0 2.1.55 4.14 1.59 5.95L0 24l6.34-1.65a11.88 11.88 0 005.7 1.45h.01c6.55 0 11.89-5.33 11.89-11.89 0-3.18-1.24-6.16-3.42-8.46"/></svg>
                </a>
                <a href={site.telegram} target="_blank" rel="noopener" aria-label="Telegram">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.78 18.65l.28-4.23 7.68-6.92c.34-.31-.07-.46-.52-.19L7.74 13.3 3.64 12c-.88-.25-.89-.86.2-1.3l15.97-6.16c.73-.33 1.43.18 1.15 1.3l-2.72 12.81c-.19.91-.74 1.13-1.5.71L12.6 16.3l-1.99 1.93c-.23.23-.42.42-.83.42z"/></svg>
                </a>
                <a href={`mailto:${site.email}`} aria-label="Email">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                </a>
                <a href={site.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
                  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/></svg>
                </a>
              </div>
              <p class="contact-line">Телефон: <a href={`tel:${site.phone}`}>{site.phoneFormatted}</a></p>
              <p class="contact-line">Email: <a href={`mailto:${site.email}`}>{site.email}</a></p>
            </div>

            <a class="contact-cal" href={site.calcom} target="_blank" rel="noopener">
              <span class="contact-cal-label">Зручніше одразу обрати час?</span>
              <span class="contact-cal-link">Забронювати слот у Cal.com →</span>
            </a>

            <p class="contact-loc">{site.founder} · Львів, Україна · дистанційно, вся Європа</p>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  .contact-page {
    background:
      radial-gradient(ellipse at top right, rgba(184, 135, 58, 0.05), transparent 55%),
      var(--bg-0);
    min-height: 100vh;
  }
  .contact-shell { max-width: 1080px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .contact-shell { padding: 0 var(--gutter-sm); } }
  .contact-hero { padding: 80px 0 96px; }
  @media (max-width: 720px) { .contact-hero { padding: 52px 0 64px; } }

  .contact-eyebrow {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--accent-pressed); margin: 0 0 16px; font-weight: 700;
  }
  .contact-h1 {
    font-family: var(--font-display); font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.02em;
    color: var(--text-1); margin: 0 0 18px;
  }
  .contact-h1 em { font-style: italic; color: var(--editorial); font-weight: 400; }
  .contact-lede {
    font-size: 18px; line-height: 1.6; color: var(--text-2); margin: 0 0 40px; max-width: 56ch;
  }

  .contact-grid { display: grid; grid-template-columns: 1.35fr 0.85fr; gap: 32px; align-items: start; }
  @media (max-width: 860px) { .contact-grid { grid-template-columns: 1fr; gap: 24px; } }

  /* Form — glass card */
  .contact-form {
    background: var(--bg-1);
    border: 1px solid var(--border-1);
    border-radius: 14px;
    padding: 32px;
    display: flex; flex-direction: column; gap: 20px;
    box-shadow: var(--shadow-md);
  }
  @media (max-width: 720px) { .contact-form { padding: 24px; } }
  .cfield { display: flex; flex-direction: column; }
  .cfield label {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--text-3); font-weight: 700; margin-bottom: 8px;
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    background: var(--bg-0);
    border: 1px solid var(--border-2);
    border-radius: 8px;
    padding: 13px 16px;
    color: var(--text-1);
    font-family: var(--font-body);
    font-size: 15px;
    width: 100%;
    transition: border-color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder { color: var(--text-4); }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    outline: none; border-color: var(--accent); background: var(--bg-2);
  }
  .contact-form textarea { min-height: 130px; resize: vertical; }
  .contact-submit { width: 100%; justify-content: center; }
  .contact-formnote { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); margin: 0; text-align: center; }

  /* Side */
  .contact-side { display: flex; flex-direction: column; gap: 20px; }
  .contact-card {
    background: var(--bg-1); border: 1px solid var(--border-1);
    border-radius: 14px; padding: 26px;
  }
  .contact-card h4 {
    font-family: var(--font-display); font-size: 17px; color: var(--text-1);
    margin: 0 0 16px; font-weight: 700;
  }
  .contact-icons { display: flex; gap: 10px; margin-bottom: 18px; flex-wrap: wrap; }
  .contact-icons a {
    width: 44px; height: 44px;
    display: inline-flex; align-items: center; justify-content: center;
    border: 1px solid var(--border-2); border-radius: 10px;
    color: var(--text-2);
    transition: color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease);
  }
  .contact-icons a:hover { color: var(--editorial); border-color: var(--accent); transform: translateY(-2px); }
  .contact-icons svg { width: 20px; height: 20px; }
  .contact-line { font-size: 14px; color: var(--text-2); margin: 0 0 6px; }
  .contact-line a { color: var(--accent-pressed); text-decoration: none; }
  .contact-line a:hover { color: var(--editorial); }

  .contact-cal {
    display: flex; flex-direction: column; gap: 4px;
    background: var(--bg-ink); color: var(--text-on-ink);
    border: 1px solid var(--border-1); border-radius: 14px;
    padding: 22px 24px; text-decoration: none;
    transition: border-color var(--dur-fast) var(--ease);
  }
  .contact-cal:hover { border-color: var(--accent); }
  .contact-cal-label { font-size: 14px; color: var(--text-on-ink-muted); }
  .contact-cal-link { font-family: var(--font-display); font-size: 16px; color: var(--editorial); font-weight: 600; }

  .contact-loc { font-family: var(--font-mono); font-size: 11px; color: var(--text-3); letter-spacing: 0.02em; margin: 0; line-height: 1.5; }
</style>
