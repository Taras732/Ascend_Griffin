---
import { site } from "../data/site";
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const howIWorkHref = isUk ? "/uk/how-i-work/" : "/how-i-work/";
---

<section class="hero" id="top">
  <div class="hero-photo">
    <img src="/taras.webp" alt={site.founder} width="1024" height="1024" fetchpriority="high" loading="eager" decoding="async" />
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-cap">
    <b>{site.founder}</b>
    <span>{isUk ? "Продуктовий радник · fractional COO" : "Product advisor · fractional COO"}</span>
  </div>

  <div class="site-container hero-grid">
    <div class="hero-text">
      <p class="hero-eyebrow"><span>{tr.site.eyebrow}</span></p>
      <h1 class="hero-h1" set:html={tr.site.heroH1Html} />
      <p class="hero-lede">{tr.site.heroLede}</p>

      <div class="hero-ctas">
        <a href="#book" data-modal="booking" data-subject="discovery-call" data-source="hero" class="btn-primary btn-lg">
          {tr.site.heroCtaPrimary}
        </a>
        <a href={howIWorkHref} class="btn-secondary btn-lg">{tr.site.heroCtaSecondary}</a>
      </div>
      {tr.site.heroMicro && <p class="hero-micro">{tr.site.heroMicro}</p>}
    </div>
  </div>
</section>

<style>
  /* HERO — full-bleed: portrait fills the right half, dissolving into a dark
     panel on the left where the text sits (cinematic direction, per site.html) */
  .hero {
    position: relative;
    min-height: clamp(600px, 86vh, 840px);
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg-0);
    border-bottom: 1px solid var(--border-1);
  }

  .hero-photo {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 52%;
    z-index: 1;
    overflow: hidden;
    margin: 0;
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    filter: contrast(103%) brightness(0.92);
  }

  /* gradient mask — solid dark on the left, transparent over the portrait */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: linear-gradient(
      to right,
      var(--bg-0) 35%,
      rgba(7, 9, 13, 0.94) 50%,
      rgba(7, 9, 13, 0.4) 80%,
      transparent 100%
    );
  }

  /* glass caption bottom-right */
  .hero-cap {
    position: absolute;
    bottom: 40px;
    right: 40px;
    z-index: 4;
    padding: 15px 20px;
    background: rgba(7, 9, 13, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-2);
    border-radius: 12px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    pointer-events: none;
  }
  .hero-cap b {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: #fff;
  }
  .hero-cap span {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--editorial);
  }

  .hero-grid {
    position: relative;
    z-index: 3;
    width: 100%;
    padding-top: 120px;
    padding-bottom: 80px;
  }
  .hero-text { max-width: 640px; min-width: 0; }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--editorial);
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 22px;
  }
  .hero-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--editorial);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.3rem, 5vw, 4.4rem);
    line-height: 1.08;
    letter-spacing: -0.015em;
    color: var(--text-1);
    margin: 0 0 24px;
    max-width: 15ch;
  }
  .hero-h1 :global(em) {
    font-style: italic;
    font-weight: 400;
    color: var(--editorial);
  }

  .hero-lede {
    font-size: clamp(1.02rem, 1.35vw, 1.2rem);
    line-height: 1.6;
    color: var(--text-2);
    max-width: 48ch;
    margin: 0 0 clamp(28px, 4vw, 40px);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-bottom: 16px;
  }
  .hero-micro {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    margin: 0;
  }

  /* ── adaptive: portrait becomes a top band, text sits below ── */
  @media (max-width: 900px) {
    .hero { min-height: 0; }
    .hero-photo {
      width: 100%;
      height: 50vh;
      min-height: 320px;
      top: 0;
      right: 0;
      bottom: auto;
    }
    .hero-photo img { object-position: center 15%; }
    .hero-overlay {
      background: linear-gradient(
        to top,
        var(--bg-0) 46%,
        rgba(7, 9, 13, 0.95) 68%,
        rgba(7, 9, 13, 0.3) 100%
      );
    }
    .hero-grid { padding-top: calc(50vh + 24px); padding-bottom: 60px; }
    .hero-text { max-width: none; }
    .hero-cap { display: none; }
  }
  @media (max-width: 560px) {
    .hero-photo { height: 42vh; min-height: 260px; }
    .hero-grid { padding-top: calc(42vh + 20px); padding-bottom: 44px; }
    .hero-h1 { font-size: clamp(1.9rem, 7.8vw, 2.5rem); }
  }
</style>
