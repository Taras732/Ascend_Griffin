---
import { site } from "../data/site";
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const howIWorkHref = isUk ? "/uk/how-i-work/" : "/how-i-work/";
---

<section class="hero" id="top">
  <div class="site-container hero-grid">
    <div class="hero-text">
      <p class="hero-eyebrow"><span>{tr.site.eyebrow}</span></p>
      <h1 class="hero-h1" set:html={tr.site.heroH1Html} />
      <p class="hero-lede">{tr.site.heroLede}</p>

      <div class="hero-ctas">
        <a href="#book" data-modal="booking" data-subject="discovery-call" data-source="hero" class="btn-primary btn-lg">
          {tr.site.heroCtaPrimary}
          <span aria-hidden="true">→</span>
        </a>
        <a href={howIWorkHref} class="btn-secondary btn-lg">{tr.site.heroCtaSecondary}</a>
      </div>
      {tr.site.heroMicro && <p class="hero-micro">{tr.site.heroMicro}</p>}
    </div>

    <div class="hero-photo">
      <img src="/taras.png" alt={site.founder} />
      <div class="hero-photo-info">
        <span class="hero-photo-name">{site.founder}</span>
        <span class="hero-photo-title">{isUk ? "Незалежний радник" : "Independent Advisor"}</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 88px 0 72px;
    border-bottom: 1px solid var(--border-1);
    background:
      radial-gradient(circle at 88% 12%, rgba(184,135,58,.06), transparent 40%),
      radial-gradient(circle at 8% 92%, rgba(184,135,58,.03), transparent 42%);
  }
  @media (max-width: 720px) {
    .hero { padding: 60px 0 56px; }
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  }
  .hero-text { min-width: 0; }

  /* Portrait card */
  .hero-photo {
    position: relative;
    width: 100%;
    max-width: 380px;
    height: 460px;
    margin-left: auto;
    border-radius: 14px;
    overflow: hidden;
    border: 1.5px solid var(--accent);
    box-shadow: var(--shadow-lg);
  }
  @media (max-width: 860px) {
    .hero-photo { order: -1; margin: 0 auto; max-width: 320px; height: 400px; }
  }
  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(102%) brightness(95%);
  }
  .hero-photo-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 22px;
    background: linear-gradient(to top, rgba(13,12,10,1) 0%, rgba(13,12,10,0.85) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .hero-photo-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: #FAF8F3;
    letter-spacing: -0.01em;
  }
  .hero-photo-title {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(250, 248, 243, 0.7);
  }
  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 0 0 28px;
  }
  .hero-eyebrow::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--accent-pressed);
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.6vw, 64px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--text-1);
    margin: 0 0 28px;
    max-width: 19ch;
  }
  .hero-h1 :global(em) {
    font-style: italic;
    font-weight: 700;
    color: var(--editorial);
  }
  .hero-lede {
    font-size: 19px;
    line-height: 1.55;
    color: var(--text-2);
    max-width: 58ch;
    margin: 0 0 40px;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-bottom: 16px;
  }
  .hero-micro {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    margin: 0;
  }
</style>
