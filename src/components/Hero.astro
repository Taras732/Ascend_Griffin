---
import { site } from "../data/site";
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
const isUk = Astro.currentLocale === "uk";
const howIWorkHref = isUk ? "/uk/how-i-work/" : "/how-i-work/";
---

<section class="hero" id="top">
  <div class="site-container hero-container">
    <div class="hero-content">
      <h1 class="hero-h1" set:html={tr.site.heroH1Html} />
      <p class="hero-lede">{tr.site.heroLede}</p>

      <div class="hero-ctas">
        <a href="#services" class="btn-primary btn-pill btn-lg">
          {tr.site.heroCtaPrimary}
        </a>
        <a href={howIWorkHref} class="btn-secondary btn-pill btn-lg">
          {tr.site.heroCtaSecondary}
        </a>
      </div>
    </div>

    <div class="hero-image-wrapper">
      <div class="hero-image-card-back"></div>
      <div class="hero-image-card-front">
        <img src="/taras.png" alt="Taras Smaliukh" class="hero-profile-img" />
        <div class="hero-profile-info">
          <span class="hero-profile-name">{site.founder}</span>
          <span class="hero-profile-title">{isUk ? "Незалежний радник & Fractional CTO" : "Independent Advisor & Fractional CTO"}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 140px 0 110px;
    border-bottom: 1px solid var(--border-1);
    position: relative;
    overflow: hidden;
  }
  @media (max-width: 900px) {
    .hero { padding: 90px 0 70px; }
  }
  .hero-container {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-container {
      grid-template-columns: 1fr;
      gap: 56px;
    }
  }
  .hero-content {
    min-width: 0;
  }
  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(34px, 4.8vw, 52px);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1.15;
    color: var(--text-1);
    margin: 0 0 28px;
    max-width: 22ch;
  }
  .hero-lede {
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-2);
    max-width: 54ch;
    margin: 0 0 40px;
    font-family: var(--font-body);
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
  }
  
  .btn-pill {
    border-radius: 50px !important;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    font-weight: 700;
  }
  .btn-primary.btn-pill {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--accent-ink);
  }
  .btn-primary.btn-pill:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(184, 135, 58, 0.25);
  }
  .btn-secondary.btn-pill {
    border: 1px solid rgba(184, 135, 58, 0.4);
    background: transparent;
    color: var(--text-1);
  }
  .btn-secondary.btn-pill:hover {
    border-color: var(--text-1);
    background: rgba(184, 135, 58, 0.05);
    transform: translateY(-2px);
  }

  /* Stacked Card Effect from Mockup */
  .hero-image-wrapper {
    position: relative;
    width: 100%;
    max-width: 410px;
    height: 500px;
    margin: 0 0 0 auto;  /* right-align in its column */
    z-index: 5;
  }
  @media (max-width: 900px) {
    .hero-image-wrapper {
      order: -1;
      height: 400px;
      max-width: 320px;
      margin: 0 auto 16px;
    }
  }
  .hero-image-card-back {
    position: absolute;
    top: 15px;
    left: 15px;
    right: -15px;
    bottom: -15px;
    background: rgba(212, 175, 55, 0.03);
    border: 1.5px solid rgba(212, 175, 55, 0.2);
    border-radius: 14px;
    z-index: 1;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 0 25px rgba(212, 175, 55, 0.02);
  }
  .hero-image-card-front {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--bg-1);
    border: 1.5px solid var(--accent);
    border-radius: 14px;
    z-index: 2;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: var(--shadow-lg);
    transition: transform var(--dur-base) var(--ease), box-shadow var(--dur-base) var(--ease), border-color var(--dur-base) var(--ease);
  }
  .hero-image-wrapper:hover .hero-image-card-front {
    transform: translate(-6px, -6px);
    box-shadow: var(--shadow-lg), 0 0 35px rgba(212, 175, 55, 0.18);
    border-color: var(--accent-hover);
  }
  .hero-profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    flex: 1;
    filter: contrast(102%) brightness(95%) grayscale(5%);
  }
  .hero-profile-info {
    padding: 24px;
    background: linear-gradient(to top, rgba(13, 12, 10, 1) 0%, rgba(13, 12, 10, 0.9) 70%, rgba(13, 12, 10, 0) 100%);
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 3;
  }
  /* Card overlay is always dark → text stays light in both themes */
  .hero-profile-name {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 700;
    color: #FAF8F3;
    letter-spacing: -0.01em;
  }
  .hero-profile-title {
    font-family: var(--font-body);
    font-size: 10px;
    color: rgba(250, 248, 243, 0.72);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 600;
  }
</style>
