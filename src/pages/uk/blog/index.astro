---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "uk" && !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = "Блог — нотатки з боку покупця | Ascend Griffin";
const description =
  "Практичні нотатки про IT-проекти, вибір вендорів, AI-інструменти і базу знань — від оператора на боці клієнта.";
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="blog-index">
    <header class="blog-hero">
      <div class="blog-shell">
        <h1 class="blog-h1">Думки <em>і нотатки</em>.</h1>
        <p class="blog-lede">
          Про IT-проєкти, AI-інструменти і документи, які ніхто не читає до підписання. Простими словами — для людей з бізнесом, а не з кодом.
        </p>
      </div>
    </header>

    <section class="blog-feed">
      <div class="blog-shell">
        {posts.length === 0 ? (
          <p class="blog-empty">Перший пост скоро.</p>
        ) : (
          <div class="blog-grid">
            {posts.map((post) => (
              <BlogCard
                href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="uk"
                tags={post.data.tags}
              />
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      name: "Ascend Griffin — Нотатки з боку покупця",
      url: "https://ascendgriffin.org/uk/blog/",
      author: { "@type": "Person", name: "Тарас Смалюх" },
      inLanguage: "uk",
    })}
  />
</BaseLayout>

<style>
  .blog-index { background: radial-gradient(ellipse at top right, rgba(184, 135, 58, 0.04), transparent 50%), var(--bg-0); min-height: 100vh; }
  .blog-shell { max-width: 1120px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .blog-shell { padding: 0 var(--gutter-sm); } }
  .blog-hero { padding: 80px 0 56px; border-bottom: 1px solid var(--border-1); }
  @media (max-width: 720px) { .blog-hero { padding: 48px 0 32px; } }
  .blog-eyebrow { font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent-pressed); margin: 0 0 16px; font-weight: 600; }
  .blog-h1 { font-family: var(--font-display); font-size: clamp(40px, 5.5vw, 68px); line-height: 1.04; letter-spacing: -0.025em; color: var(--text-1); margin: 0 0 24px; font-weight: 700; max-width: 14ch; }
  .blog-h1 em { font-style: italic; color: var(--editorial); }
  .blog-lede { font-size: 19px; line-height: 1.6; color: var(--text-2); margin: 0; max-width: 60ch; }
  .blog-feed { padding: 56px 0 96px; }
  .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  @media (max-width: 720px) { .blog-grid { grid-template-columns: 1fr; } }
  .blog-empty { font-family: var(--font-mono); font-size: 14px; color: var(--text-3); line-height: 1.6; max-width: 60ch; }
</style>
