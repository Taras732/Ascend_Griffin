---
interface Props {
  service?: "audit" | "discovery" | "rescue" | "support";
  spotsLeft?: number;
  deadline?: string;
}

const { service = "discovery", spotsLeft = 2, deadline } = Astro.props;
const isUk = Astro.currentLocale === "uk";

const copy = isUk
  ? {
      eyebrow: `Founding Discovery — ${spotsLeft} місця залишилось`,
      h: "Перші клієнти отримують більше моєї уваги.",
      body:
        "Ascend Griffin у фазі валідації. Це означає, що ці кілька перших розмов я веду особисто і глибше, ніж робитиму через 12 місяців. Якщо цей контекст важливий для вашого рішення — це ваш момент.",
      cta: "Discovery Call · 30 хв",
      footnote: deadline ? `Founding-набір закривається ${deadline}.` : "Кількість обмежена.",
    }
  : {
      eyebrow: `Founding Discovery — ${spotsLeft} spots left`,
      h: "Early clients get more of my attention.",
      body:
        "Ascend Griffin is in validation phase. That means these first conversations I run personally and deeper than I will twelve months from now. If that context matters to your decision — this is your window.",
      cta: "Book Discovery Call · 30 min",
      footnote: deadline ? `Founding cohort closes ${deadline}.` : "Limited spots.",
    };
---

<section class="founding-cta">
  <div class="content-shell">
    <div class="founding-card">
      <p class="founding-eyebrow">{copy.eyebrow}</p>
      <h2 class="founding-h">{copy.h}</h2>
      <p class="founding-body">{copy.body}</p>
      <a
        href="#book"
        class="founding-btn"
        data-modal="booking"
        data-subject={service === "audit" ? "audit" : service === "discovery" ? "discovery" : service === "support" ? "support" : "discovery-call"}
        data-source={`founding-cta-${service}`}
      >
        {copy.cta} →
      </a>
      <p class="founding-footnote">{copy.footnote}</p>
    </div>
  </div>
</section>

<style>
  .founding-cta {
    padding: 56px 0 80px;
  }
  .founding-card {
    background: var(--bg-ink);
    color: var(--text-on-ink);
    padding: 56px 48px;
    border-radius: 4px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  @media (max-width: 720px) {
    .founding-card { padding: 40px 24px; }
  }
  .founding-card::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(184,135,58,.08), transparent 60%);
    pointer-events: none;
  }
  .founding-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 18px;
    font-weight: 600;
    position: relative;
  }
  .founding-h {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 36px);
    color: var(--text-on-ink);
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 20px;
    font-weight: 700;
    position: relative;
  }
  .founding-body {
    color: var(--text-on-ink-muted);
    font-size: 16px;
    line-height: 1.6;
    max-width: 60ch;
    margin: 0 auto 32px;
    position: relative;
  }
  .founding-btn {
    display: inline-block;
    background: var(--accent);
    color: var(--accent-ink);
    padding: 16px 32px;
    text-decoration: none;
    font-weight: 600;
    border-radius: 2px;
    font-size: 15px;
    letter-spacing: 0.02em;
    transition: background var(--dur-fast) var(--ease);
    position: relative;
  }
  .founding-btn:hover { background: var(--accent-hover); }
  .founding-footnote {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-on-ink-muted);
    letter-spacing: 0.04em;
    margin: 20px 0 0;
    position: relative;
  }
</style>
