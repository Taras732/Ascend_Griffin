---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="page-main">
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .page-main {
    min-height: calc(100vh - 200px);
  }

  /* Content page shell */
  .content-page {
    padding: 80px 0 120px;
  }
  @media (max-width: 720px) {
    .content-page { padding: 56px 0 80px; }
  }

  .content-shell {
    max-width: 760px;
    padding: 0 var(--gutter);
    margin: 0 auto;
  }
  @media (max-width: 720px) {
    .content-shell { padding: 0 var(--gutter-sm); }
  }

  .content-shell-wide {
    max-width: var(--container);
    padding: 0 var(--gutter);
    margin: 0 auto;
  }
  @media (max-width: 720px) {
    .content-shell-wide { padding: 0 var(--gutter-sm); }
  }

  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    margin: 0 0 18px;
    font-weight: 600;
  }

  .page-h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 56px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--text-1);
    margin: 0 0 22px;
    font-weight: 700;
  }
  .page-h1 em {
    font-style: normal;
    color: var(--editorial);
  }

  .page-lede {
    font-size: 19px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0 0 56px;
    max-width: 60ch;
  }

  .content-section { margin: 0 0 56px; }
  .content-section h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--text-1);
    margin: 0 0 18px;
    font-weight: 700;
  }
  .content-section h3 {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--text-1);
    margin: 28px 0 12px;
    font-weight: 600;
  }
  .content-section p {
    font-size: 17px;
    line-height: 1.65;
    color: var(--text-2);
    margin: 0 0 18px;
  }
  .content-section p strong { color: var(--text-1); }
  .content-section ul, .content-section ol {
    margin: 0 0 18px;
    padding-left: 22px;
    color: var(--text-2);
  }
  .content-section li {
    margin-bottom: 8px;
    line-height: 1.55;
  }
  .content-section blockquote {
    border-left: 3px solid var(--accent);
    padding: 4px 0 4px 20px;
    margin: 24px 0;
    color: var(--text-1);
    font-style: italic;
    background: var(--accent-subtle);
    border-radius: 0 2px 2px 0;
  }
  .content-section blockquote p { margin: 0; }
  .content-section a {
    color: var(--accent-pressed);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--dur-fast) var(--ease);
  }
  .content-section a:hover { color: var(--accent-hover); }
  .content-section hr {
    border: 0;
    border-top: 1px solid var(--border-1);
    margin: 40px 0;
  }
  .content-section table {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0;
    font-size: 15px;
  }
  .content-section th, .content-section td {
    border: 1px solid var(--border-1);
    padding: 10px 14px;
    text-align: left;
  }
  .content-section th {
    background: var(--bg-1);
    font-weight: 600;
    color: var(--text-1);
  }

  .illustrative-label {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-3);
    font-style: italic;
    margin: -6px 0 12px;
    letter-spacing: 0.02em;
  }
</style>
