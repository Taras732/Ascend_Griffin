---
import { site } from "../data/site";

const isUk = Astro.currentLocale === "uk";
const homeHref = isUk ? "/uk/" : "/";

// Switch language while preserving the current page path
// /uk/about/  → /about/    (drop /uk prefix)
// /about/     → /uk/about/ (add /uk prefix)
// /uk/        → /          (root)
// /           → /uk/       (root)
const pathname = Astro.url.pathname || "/";
const altLangHref = isUk
  ? pathname.replace(/^\/uk(\/|$)/, "/") || "/"
  : ("/uk" + pathname).replace(/\/$/, "/");
const altLangLabel = isUk ? "EN" : "UA";

const labels = isUk
  ? {
      services: "Послуги",
      about: "Про мене",
      howIWork: "Як я працюю",
      blog: "Блог",
      cta: "Стратегічна сесія",
      menu: "Меню",
      altLangAria: `Switch to English`,
    }
  : {
      services: "Services",
      about: "About",
      howIWork: "How I work",
      blog: "Blog",
      cta: "Request Strategy Session",
      menu: "Menu",
      altLangAria: `Switch to Ukrainian`,
    };

const prefix = isUk ? "/uk" : "";
const links = {
  services: `${prefix}/#services`,
  about: `${prefix}/about/`,
  howIWork: `${prefix}/how-i-work/`,
  blog: `${prefix}/blog/`,
};
---

<nav class="site-nav" aria-label="Primary">
  <div class="site-container nav-inner">
    <a href={homeHref} class="nav-brand" aria-label={`${site.name} — home`}>
      <span class="nav-brand-mark" role="img" aria-label="Ascend Griffin"></span>
      <span class="nav-brand-name">{site.name}</span>
    </a>

    <button class="nav-toggle" aria-label={labels.menu} aria-controls="nav-links" aria-expanded="false">
      {labels.menu}
    </button>

    <ul class="nav-links" id="nav-links">
      <li><a href={links.services}>{labels.services}</a></li>
      <li><a href={links.howIWork}>{labels.howIWork}</a></li>
      <li><a href={links.about}>{labels.about}</a></li>
      <li><a href={links.blog}>{labels.blog}</a></li>
      <li>
        <button class="nav-theme-toggle" type="button" aria-label={isUk ? "Перемкнути тему" : "Toggle theme"} title={isUk ? "Світла / темна тема" : "Light / dark theme"}>
          <svg class="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
          <svg class="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </li>
      <li>
        <a href={altLangHref} class="nav-lang" aria-label={labels.altLangAria}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            <path d="M2 12h20" />
          </svg>
          <span>{altLangLabel}</span>
        </a>
      </li>
      <li>
        <a href="#book" data-modal="booking" data-subject="discovery-call" data-source="nav" class="nav-cta-pill">
          {labels.cta}
        </a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--nav-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-1);
    transition: background var(--dur-base) var(--ease);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px var(--gutter);
    max-width: var(--container);
    margin: 0 auto;
  }
  @media (max-width: 720px) { .nav-inner { padding: 14px var(--gutter-sm); } }
  
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: var(--text-1);
  }
  /* Logo badge — golden griffin cropped from the brand PNG on a dark plate */
  .nav-brand-mark {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background-image: url("/logo/ascend-griffin-full.png");
    background-repeat: no-repeat;
    background-color: #16140F;
    background-size: 85px;
    background-position: -22px -14px;
    box-shadow: 0 0 0 1px var(--accent-border), 0 2px 10px rgba(193, 154, 60, 0.18);
    transition: transform var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }
  .nav-brand:hover .nav-brand-mark {
    transform: scale(1.05);
    box-shadow: 0 0 0 1px var(--accent), 0 4px 16px rgba(193, 154, 60, 0.3);
  }
  .nav-brand-name {
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-1);
  }
  
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-links > li > a {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-3);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
    padding: 6px 0;
    position: relative;
    letter-spacing: 0.02em;
  }
  .nav-links > li > a:hover {
    color: var(--text-1);
  }
  
  /* Theme toggle */
  .nav-theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: 1px solid var(--border-2);
    border-radius: 50px;
    background: transparent;
    color: var(--text-2);
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease);
  }
  .nav-theme-toggle:hover {
    border-color: var(--accent);
    color: var(--accent-pressed);
    background: var(--accent-subtle);
  }
  /* Light theme → show moon (switch to dark). Dark theme → show sun. */
  .nav-theme-toggle .theme-icon-sun,
  .nav-theme-toggle .theme-icon-moon { display: block; }
  .nav-theme-toggle .theme-icon-sun { display: none; }
  :global(html[data-theme="dark"]) .nav-theme-toggle .theme-icon-sun { display: block; }
  :global(html[data-theme="dark"]) .nav-theme-toggle .theme-icon-moon { display: none; }

  /* Language toggle */
  .nav-lang {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: 1px solid rgba(212, 175, 55, 0.25);
    padding: 6px 12px;
    border-radius: 50px;
    color: var(--text-2) !important;
    font-weight: 600;
    font-size: 11px;
    font-family: var(--font-mono);
    transition: all var(--dur-fast) var(--ease);
  }
  .nav-lang svg { color: var(--accent); flex-shrink: 0; }
  .nav-lang:hover {
    border-color: var(--accent);
    color: var(--text-1) !important;
    background: rgba(212, 175, 55, 0.08);
  }

  /* Pill outline CTA from mockup */
  .nav-cta-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--accent);
    border-radius: 50px;
    padding: 10px 22px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    color: var(--accent-pressed) !important;
    background: transparent;
    transition: all var(--dur-base) var(--ease);
    letter-spacing: 0.01em;
    cursor: pointer;
    white-space: nowrap;
  }
  .nav-cta-pill:hover {
    background: var(--accent);
    color: var(--accent-ink) !important;
    box-shadow: 0 4px 15px rgba(184, 135, 58, 0.15);
    transform: translateY(-1px);
  }

  /* Toggle */
  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--border-2);
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-1);
    cursor: pointer;
    border-radius: 2px;
  }

  /* Mobile */
  @media (max-width: 860px) {
    .nav-links { display: none; }
    .nav-toggle { display: block; }
    .nav-links.open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-0);
      padding: 20px var(--gutter-sm);
      border-bottom: 1px solid var(--border-1);
      align-items: stretch;
      gap: 14px;
      max-height: calc(100vh - 64px);
      overflow-y: auto;
    }
    .nav-links.open > li {
      width: 100%;
    }
    .nav-dropdown-menu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: 0;
      border-left: 2px solid var(--border-2);
      border-radius: 0;
      padding: 4px 0 4px 12px;
      margin-top: 8px;
      display: none;
    }
    .nav-dropdown.is-open .nav-dropdown-menu { display: block; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const links = document.getElementById("nav-links");
  if (toggle && links) {
    toggle.addEventListener("click", () => {
      const open = links.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    links.querySelectorAll<HTMLAnchorElement>("a:not(.nav-dropdown-trigger)").forEach((a) => {
      a.addEventListener("click", () => {
        links.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Theme toggle — light (default) ↔ dark, persisted in localStorage
  document.querySelectorAll<HTMLButtonElement>(".nav-theme-toggle").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isDark = document.documentElement.getAttribute("data-theme") === "dark";
      const next = isDark ? "light" : "dark";
      if (next === "dark") {
        document.documentElement.setAttribute("data-theme", "dark");
      } else {
        document.documentElement.removeAttribute("data-theme");
      }
      try { localStorage.setItem("ag_theme", next); } catch (e) { /* ignore */ }
    });
  });

  // Dropdown click behavior (mobile + accessibility)
  document.querySelectorAll<HTMLElement>(".nav-dropdown").forEach((dd) => {
    const trigger = dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger");
    if (!trigger) return;
    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      const isOpen = dd.classList.toggle("is-open");
      trigger.setAttribute("aria-expanded", String(isOpen));
    });
  });

  // Set lang-redirect flag BEFORE navigation so root-level auto-redirect script
  // doesn't override an explicit user choice. Fixes "first click doesn't work" bug.
  document.querySelectorAll<HTMLAnchorElement>(".nav-lang").forEach((link) => {
    link.addEventListener("click", () => {
      try { sessionStorage.setItem("ag_lang_redirect_done", "1"); } catch (e) { /* ignore */ }
    });
  });

  // Close dropdowns on outside click + Escape
  document.addEventListener("click", (e) => {
    document.querySelectorAll<HTMLElement>(".nav-dropdown.is-open").forEach((dd) => {
      if (!dd.contains(e.target as Node)) {
        dd.classList.remove("is-open");
        dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger")?.setAttribute("aria-expanded", "false");
      }
    });
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      document.querySelectorAll<HTMLElement>(".nav-dropdown.is-open").forEach((dd) => {
        dd.classList.remove("is-open");
        dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger")?.setAttribute("aria-expanded", "false");
      });
    }
  });
</script>
