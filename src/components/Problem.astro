---
import { problems } from "../data/problems";
---

<section class="section problem-section" id="problem">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">03 · Результат</div>
      <div class="section-head-body">
        <h2>Чотири шляхи до <em>результату</em>.</h2>
        <p class="lede">
          На кожній стадії вашого проекту — свій контекст і відповідний результат. Ось чотири сценарії, у яких працюю: від перевірки ідеї до масштабування й оптимізації готових продуктів.
        </p>
      </div>
    </div>

    <div class="problem-grid">
      {problems.map((p) => (
        <article class="problem-card">
          <div class="problem-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              {p.icon === "lightbulb" && (
                <>
                  <path d="M9 18h6" />
                  <path d="M10 22h4" />
                  <path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14" />
                </>
              )}
              {p.icon === "rocket" && (
                <>
                  <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
                  <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
                  <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
                  <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
                </>
              )}
              {p.icon === "compass" && (
                <>
                  <circle cx="12" cy="12" r="10" />
                  <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" />
                </>
              )}
              {p.icon === "refresh-cw" && (
                <>
                  <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
                  <path d="M21 3v5h-5" />
                  <path d="M3 12a9 9 0 0 0 15.74 6.26L21 16" />
                  <path d="M16 16h5v5" />
                </>
              )}
            </svg>
          </div>
          <h3>{p.title}</h3>
          <p class="problem-desc">{p.description}</p>
          <div class="problem-steps">
            <div class="problem-label">Етапи</div>
            <ol>
              {p.steps.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </div>
          <a href={`#package-${p.packageId}`} class="problem-link">
            Рекомендований формат: <strong>{p.packageLabel}</strong> <span aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .problem-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 2px solid var(--accent);
    border-left: 1px solid var(--border-1);
  }
  .problem-card {
    padding: 36px 28px;
    border-right: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    background: var(--bg-0);
    display: flex;
    flex-direction: column;
  }
  .problem-icon {
    color: var(--editorial);
    margin-bottom: 22px;
  }
  .problem-card h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 18px;
  }
  .problem-desc {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 24px;
  }
  .problem-steps {
    padding-top: 20px;
    border-top: 1px solid var(--border-1);
    margin-top: auto;
  }
  .problem-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 12px;
  }
  .problem-steps ol {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
  }
  .problem-steps li {
    position: relative;
    padding-left: 28px;
    margin-bottom: 10px;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-2);
    counter-increment: step;
  }
  .problem-steps li:last-child {
    margin-bottom: 0;
  }
  .problem-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--border-1);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--text-3);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .problem-link strong {
    color: var(--accent-pressed);
    font-weight: 600;
  }
  .problem-link:hover {
    color: var(--text-1);
  }
  .problem-link:hover strong {
    color: var(--accent);
  }
  .problem-steps li::before {
    content: counter(step, decimal-leading-zero);
    position: absolute;
    left: 0;
    top: 1px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--editorial);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
  @media (max-width: 860px) {
    .problem-grid { grid-template-columns: 1fr; }
  }
</style>
