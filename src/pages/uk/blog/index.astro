---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Nav from "../../../components/Nav.astro";
import Footer from "../../../components/Footer.astro";
import BlogCard from "../../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "uk" && !data.draft);

// Series groupings
type Post = (typeof allPosts)[number];
const seriesGroups: Map<string, Post[]> = new Map();
const soloPosts: Post[] = [];

for (const post of allPosts) {
  if (post.data.series) {
    if (!seriesGroups.has(post.data.series)) seriesGroups.set(post.data.series, []);
    seriesGroups.get(post.data.series)!.push(post);
  } else {
    soloPosts.push(post);
  }
}

// Sort each series by seriesOrder ascending
for (const [, posts] of seriesGroups) {
  posts.sort((a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999));
}

// Sort solo posts by pubDate descending
soloPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Series metadata (intro + label)
const seriesMeta: Record<string, { label: string; intro: string }> = {
  "obsidian-ai": {
    label: "Серія · Obsidian + AI",
    intro:
      "Як побудувати власну базу знань на Obsidian з підключенням AI — від нуля до робочого ритуалу. Читати краще за порядком: кожен пост опирається на попередній.",
  },
};

// All unique tags across non-draft posts (for tag pill row)
const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);

const title = "Блог — нотатки з боку покупця | Ascend Griffin";
const description =
  "Практичні нотатки про IT-проекти, AI-інструменти та інші практики, якими я користуюсь у роботі.";
---

<BaseLayout title={title} description={description}>
  <Nav />
  <main class="blog-index">
    <header class="blog-hero">
      <div class="blog-shell">
        <h1 class="blog-h1">Думки <em>і нотатки</em>.</h1>
        <p class="blog-lede">
          Про IT-проєкти, AI-інструменти та інші практики, якими я користуюсь у роботі. Простими словами.
        </p>

        {tags.length > 0 && (
          <div class="tag-row" role="list" aria-label="Теми">
            {tags.map(([tag, count]) => (
              <span class="tag-pill" role="listitem">
                <span class="tag-pill-name">#{tag}</span>
                <span class="tag-pill-count">{count}</span>
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    {/* ── Series ────────────────────────────────────────────────── */}
    {Array.from(seriesGroups.entries()).map(([seriesKey, posts]) => (
      <section class="series-section">
        <div class="blog-shell">
          <div class="series-header">
            <p class="series-label">{seriesMeta[seriesKey]?.label ?? seriesKey}</p>
            <p class="series-count">{posts.length} {posts.length === 1 ? "стаття" : posts.length < 5 ? "статті" : "статей"}</p>
          </div>
          {seriesMeta[seriesKey]?.intro && (
            <p class="series-intro">{seriesMeta[seriesKey].intro}</p>
          )}

          <ol class="series-list">
            {posts.map((post, i) => (
              <li class="series-item">
                <a href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`} class="series-link">
                  <span class="series-num">{String(i + 1).padStart(2, "0")}</span>
                  <span class="series-content">
                    <span class="series-title">{post.data.title}</span>
                    <span class="series-desc">{post.data.description}</span>
                    <span class="series-meta">
                      <time datetime={post.data.pubDate.toISOString()}>
                        {post.data.pubDate.toLocaleDateString("uk-UA", { year: "numeric", month: "long", day: "numeric" })}
                      </time>
                      {post.data.readingTime && (
                        <>
                          <span class="dot">·</span>
                          <span>{post.data.readingTime}</span>
                        </>
                      )}
                    </span>
                  </span>
                  <span class="series-arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ol>
        </div>
      </section>
    ))}

    {/* ── Solo posts ───────────────────────────────────────────── */}
    {soloPosts.length > 0 && (
      <section class="solo-section">
        <div class="blog-shell">
          <p class="series-label">Окремі статті</p>
          <div class="blog-grid">
            {soloPosts.map((post) => (
              <BlogCard
                href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="uk"
                tags={post.data.tags}
              />
            ))}
          </div>
        </div>
      </section>
    )}

    {seriesGroups.size === 0 && soloPosts.length === 0 && (
      <div class="blog-shell">
        <p class="blog-empty">Перший пост скоро.</p>
      </div>
    )}
  </main>
  <Footer />

  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Blog",
      name: "Ascend Griffin — Нотатки з боку покупця",
      url: "https://ascendgriffin.org/uk/blog/",
      author: { "@type": "Person", name: "Тарас Смалюх" },
      inLanguage: "uk",
    })}
  />
</BaseLayout>

<style>
  .blog-index { background: radial-gradient(ellipse at top right, rgba(184, 135, 58, 0.04), transparent 50%), var(--bg-0); min-height: 100vh; }
  .blog-shell { max-width: 1120px; margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .blog-shell { padding: 0 var(--gutter-sm); } }

  .blog-hero { padding: 80px 0 40px; border-bottom: 1px solid var(--border-1); }
  @media (max-width: 720px) { .blog-hero { padding: 48px 0 28px; } }
  .blog-h1 { font-family: var(--font-display); font-size: clamp(40px, 5.5vw, 68px); line-height: 1.04; letter-spacing: -0.025em; color: var(--text-1); margin: 0 0 20px; font-weight: 700; max-width: 14ch; }
  .blog-h1 em { font-style: italic; color: var(--editorial); }
  .blog-lede { font-size: 19px; line-height: 1.6; color: var(--text-2); margin: 0 0 32px; max-width: 60ch; }

  /* Tag row */
  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
  .tag-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    padding: 5px 12px;
    background: var(--bg-1);
    border: 1px solid var(--border-1);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-2);
  }
  .tag-pill-name { color: var(--text-1); }
  .tag-pill-count {
    font-size: 11px;
    color: var(--text-3);
    background: var(--bg-0);
    padding: 1px 6px;
    border-radius: 999px;
  }

  /* Series sections */
  .series-section { padding: 56px 0; border-bottom: 1px solid var(--border-1); }
  .series-section:last-of-type { border-bottom: 0; }
  @media (max-width: 720px) { .series-section { padding: 40px 0; } }

  .series-header { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 8px; }
  .series-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-pressed);
    margin: 0;
    font-weight: 700;
  }
  .series-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    margin: 0;
  }
  .series-intro {
    font-size: 16px;
    line-height: 1.55;
    color: var(--text-2);
    max-width: 60ch;
    margin: 0 0 32px;
  }

  .series-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--text-1);
  }
  .series-item { margin: 0; }
  .series-link {
    display: grid;
    grid-template-columns: 64px 1fr 32px;
    gap: 20px;
    align-items: center;
    padding: 24px 0;
    border-bottom: 1px solid var(--border-1);
    text-decoration: none;
    color: inherit;
    transition: background var(--dur-fast) var(--ease);
  }
  .series-link:hover {
    background: var(--bg-1);
  }
  .series-link:hover .series-arrow {
    color: var(--accent-pressed);
    transform: translateX(4px);
  }
  @media (max-width: 720px) {
    .series-link { grid-template-columns: 40px 1fr 24px; gap: 14px; padding: 20px 0; }
  }
  .series-num {
    font-family: var(--font-mono);
    font-size: 22px;
    color: var(--accent-pressed);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .series-content {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }
  .series-title {
    font-family: var(--font-display);
    font-size: clamp(18px, 2.2vw, 21px);
    line-height: 1.25;
    color: var(--text-1);
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .series-desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--text-2);
    max-width: 68ch;
  }
  .series-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.02em;
    margin-top: 2px;
  }
  .series-meta .dot { margin: 0 6px; }
  .series-arrow {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--text-4);
    text-align: right;
    transition: all var(--dur-fast) var(--ease);
  }

  /* Solo posts grid */
  .solo-section { padding: 56px 0; }
  @media (max-width: 720px) { .solo-section { padding: 40px 0; } }
  .blog-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; margin-top: 20px; }
  @media (max-width: 720px) { .blog-grid { grid-template-columns: 1fr; } }
  .blog-empty { font-family: var(--font-mono); font-size: 14px; color: var(--text-3); padding: 40px 0; }
</style>
