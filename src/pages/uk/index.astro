---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import Hero from "../../components/Hero.astro";
import TrustBlock from "../../components/TrustBlock.astro";
import FoundingCTA from "../../components/FoundingCTA.astro";
import Footer from "../../components/Footer.astro";
import BlogCard from "../../components/BlogCard.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog", ({ data }) => data.lang === "uk" && !data.draft);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

const services = [
  {
    num: "01",
    title: "Аудит AI-готовності",
    price: "від $1,000 · 5-14 днів",
    desc: "Незалежна оцінка вашого прототипу, пропозицій від вендора або чинної AI-інтеграції. Перед тим, як вкладати додатковий капітал — структурований аудит коду та ризиків.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg>`,
    href: "/uk/ai-readiness-audit/"
  },
  {
    num: "02",
    title: "Продуктове дослідження",
    price: "від $4,000 · 2-8 тижнів",
    desc: "Discovery Sprint для нетехнічних засновників. Перетворюємо ідею на протестований концепт, реалістичний бюджет, архітектуру системи та короткий список перевірених вендорів.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>`,
    href: "/uk/idea-translator/"
  },
  {
    num: "03",
    title: "Відновлення проєкту",
    price: "від $2,500 / міс · retainer",
    desc: "Коли проєкт втратив темп, комунікація з вендором зайшла в глухий кут, або бюджет тане без видимих результатів. Структурне відновлення та чіткий план порятунку.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
    href: "/uk/project-rescue/"
  },
  {
    num: "04",
    title: "Fractional PO / CTO",
    price: "від $2,500 / міс · retainer",
    desc: "Роль вашого внутрішнього Product Owner або технічного радника. Перевірка контрактів та оцінок виконавців, участь у демо-зустрічах та повний контроль за якістю розробки.",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>`,
    href: "/uk/how-i-work/"
  }
];
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />

    {/* ── Сервіси ─────────────────────────────────────────────── */}
    <section class="home-section" id="services">
      <div class="home-shell">
        <h2 class="section-title-caps">КЛЮЧОВІ ПОСЛУГИ</h2>
        
        <div class="services-grid-redesign">
          {services.map((service) => (
            <a href={service.href} class="service-card-redesign glass-card">
              <div class="service-icon-badge" set:html={service.icon} />
              <h3 class="service-card-title-redesign">{service.title}</h3>
              <p class="service-card-price-redesign">{service.price}</p>
              <p class="service-card-desc-redesign">{service.desc}</p>
              <span class="service-card-link-redesign">Дізнатись більше →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <TrustBlock />

    {/* ── Про мене teaser ─────────────────────────────────────── */}
    <section class="home-section home-section-bg">
      <div class="home-shell">
        <h2 class="section-title-caps">ХТО Я</h2>
        <div class="prose-redesign">
          <p class="prose-lead">Я бачу приховані ризики в IT-проєктах до того, як вони перетворяться на дорогі помилки.</p>
          <p>Я — Тарас Смалюх, CEO і CPO TreximAI (B2B AI-платформа логістики), засновник Ascend Griffin. 8 років бізнес-аналізу і продуктового менеджменту у AI-продуктах, логістиці, фінтеху та B2B SaaS.</p>
          <p>Моя сильна сторона — читати IT-проєкт як цілісну систему і бачити, де ризики, які інші не помічають. Скоуп, оцінки, продуктові рішення, технічні припущення, що звучать переконливо, але не тримають під тиском.</p>
          <p>Я не виступаю безпосереднім розробником у ваших проєктах — але добре розумію архітектуру і працюю з сучасними AI-інструментами. Коли потрібно масштабувати систему — ми залучаємо технічну команду: вашу, якщо вже є, або підбираємо перевірених фахівців з моєї мережі.</p>
        </div>
        <a href="/uk/about/" class="link-arrow-redesign">Дізнатись більше про мене →</a>
      </div>
    </section>

    {/* ── Як це працює teaser ──────────────────────────────────── */}
    <section class="home-section">
      <div class="home-shell">
        <h2 class="section-title-caps">ЯК Я ПРАЦЮЮ</h2>
        <p class="home-lede-redesign">
          Це контракт перед контрактом. Кожна співпраця — Аудит, Дослідження, Супровід — працює за цими п'ятьма правилами.
        </p>

        <div class="principles-grid">
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">01</span>
            <h4>Завжди на вашому боці</h4>
            <p>Мої рекомендації служать виключно вашим інтересам. Жодних прихованих відсотків чи домовленостей з вендорами.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">02</span>
            <h4>Ціна фіксована до старту</h4>
            <p>Без погодинної оплати. Ціна погоджується до початку робіт. Жодних тихих змін у бюджеті під час проєкту.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">03</span>
            <h4>Спершу дослідження</h4>
            <p>Якщо я не є правильним фахівцем для вашої ситуації — я скажу про це на першому безкоштовному дзвінку.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">04</span>
            <h4>Задокументований слід</h4>
            <p>Кожне рішення, рекомендація чи аудит надаються у формі чітких звітів для ваших записів та ради директорів.</p>
          </div>
          <div class="principle-item glass-card">
            <span class="principle-num-redesign">05</span>
            <h4>Робота на результат</h4>
            <p>Без роботи заради процесу. Ми оцінюємо успіх за реальними бізнес-результатами, а не за відпрацьованими годинами.</p>
          </div>
        </div>

        <a href="/uk/how-i-work/" class="link-arrow-redesign">Детальніше про принципи →</a>
      </div>
    </section>

    {/* ── Блог teaser ─────────────────────────────────────────── */}
    {latestPosts.length > 0 && (
      <section class="home-section home-section-bg">
        <div class="home-shell">
          <h2 class="section-title-caps">З БЛОГУ</h2>
          <p class="home-lede-redesign">Думки та спостереження про IT-проєкти, AI-інструменти та продуктові практики.</p>

          <div class="blog-teaser-grid-redesign">
            {latestPosts.map((post) => (
              <BlogCard
                href={`/uk/blog/${post.id.replace(/^uk\//, "")}/`}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                lang="uk"
                tags={post.data.tags}
              />
            ))}
          </div>

          <a href="/uk/blog/" class="link-arrow-redesign" style="margin-top: 40px;">Всі статті →</a>
        </div>
      </section>
    )}

    <FoundingCTA service="discovery" />
  </main>
  <Footer />

  <script is:inline>
    // Browser language redirect — only on first visit, only for root EN page
    (function () {
      try {
        var REDIRECTED_KEY = "ag_lang_redirect_done";
        if (sessionStorage.getItem(REDIRECTED_KEY)) return;
        var lang = (navigator.language || "en").toLowerCase();
        if (lang.indexOf("uk") === 0) {
          sessionStorage.setItem(REDIRECTED_KEY, "1");
          window.location.replace("/uk/");
        }
      } catch (e) {
        /* ignore */
      }
    })();
  </script>
</BaseLayout>

<style>
  .home-shell { max-width: var(--container); margin: 0 auto; padding: 0 var(--gutter); }
  @media (max-width: 720px) { .home-shell { padding: 0 var(--gutter-sm); } }

  .home-section { padding: 100px 0; border-top: 1px solid var(--border-1); }
  @media (max-width: 720px) { .home-section { padding: 64px 0; } }
  .home-section-bg { background: var(--bg-1); }

  .section-title-caps {
    font-family: var(--font-display);
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
    margin: 0 0 40px;
    font-weight: 700;
  }

  .home-lede-redesign {
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 40px;
    max-width: 60ch;
  }

  /* 4-column Services Grid from Mockup */
  .services-grid-redesign {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
  }
  @media (max-width: 1024px) {
    .services-grid-redesign { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .services-grid-redesign { grid-template-columns: 1fr; }
  }

  .service-card-redesign {
    border-radius: 12px;
    padding: 32px 24px;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    min-height: 320px;
    border: 1px solid var(--border-1);
  }
  .service-icon-badge {
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--accent);
    color: var(--accent-ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    box-shadow: 0 4px 12px rgba(212, 175, 55, 0.18);
    transition: transform var(--dur-base) var(--ease), background-color var(--dur-base) var(--ease);
  }
  .service-card-redesign:hover .service-icon-badge {
    transform: scale(1.08) rotate(3deg);
    background: var(--accent-hover);
  }
  .service-card-title-redesign {
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.25;
    letter-spacing: -0.01em;
    color: var(--text-1);
    margin: 0 0 6px;
    font-weight: 700;
  }
  .service-card-price-redesign {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    margin: 0 0 16px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .service-card-desc-redesign {
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-2);
    margin: 0;
    flex: 1;
  }
  .service-card-link-redesign {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.04em;
    font-weight: 700;
    margin-top: 24px;
    text-transform: uppercase;
  }

  .prose-redesign p { font-size: 17px; line-height: 1.7; color: var(--text-2); margin: 0 0 18px; max-width: 65ch; }
  .prose-redesign p:last-child { margin-bottom: 0; }
  .prose-lead { font-size: 22px !important; font-weight: 600; color: var(--text-1); line-height: 1.4 !important; margin-bottom: 24px !important; }

  .link-arrow-redesign {
    display: inline-block;
    margin-top: 32px;
    color: var(--accent-pressed);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.04em;
    font-weight: 700;
    border-bottom: 1.5px solid var(--accent);
    padding-bottom: 2px;
    transition: color var(--dur-fast) var(--ease);
    text-transform: uppercase;
  }
  .link-arrow-redesign:hover { color: var(--accent-hover); }

  /* 5 Principles Grid Redesign */
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 16px;
  }
  @media (max-width: 1024px) {
    .principles-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .principles-grid { grid-template-columns: 1fr; }
  }
  .principle-item {
    padding: 24px 20px;
    border-radius: 6px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .principle-num-redesign {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent-pressed);
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .principle-item h4 {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    color: var(--text-1);
    margin: 0;
  }
  .principle-item p {
    font-size: 13px;
    line-height: 1.5;
    color: var(--text-3);
    margin: 0;
  }

  .blog-teaser-grid-redesign {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }
  @media (max-width: 720px) { .blog-teaser-grid-redesign { grid-template-columns: 1fr; } }
</style>
