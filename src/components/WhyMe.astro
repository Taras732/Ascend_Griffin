---
import { pillars } from "../data/pillars";
---

<section class="section why-section" id="why">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">06 · Why me</div>
      <div class="section-head-body">
        <h2>Три <em>pillars</em>. Не 12 buzz-slides.</h2>
        <p class="lede">
          Accountability. Рішення замість документів. Practitioner CEO, а не consultant.
          Все інше — derivative цих трьох.
        </p>
      </div>
    </div>

    <div class="why-grid">
      {pillars.map((p) => (
        <article class="why-item">
          <div class="why-num">{p.num}</div>
          <h3>{p.title}</h3>
          <p class="why-body">{p.body}</p>
          <div class="why-proof">{p.proof}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--border-1);
    border-left: 1px solid var(--border-1);
  }
  .why-item {
    padding: 40px 28px 32px;
    border-right: 1px solid var(--border-1);
    border-bottom: 1px solid var(--border-1);
    background: var(--bg-0);
    display: flex;
    flex-direction: column;
  }
  .why-num {
    font-family: var(--font-mono);
    font-size: 56px;
    font-weight: 500;
    letter-spacing: -0.03em;
    color: var(--editorial);
    line-height: 1;
    margin-bottom: 20px;
    font-variant-numeric: tabular-nums;
  }
  .why-item h3 {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 14px;
  }
  .why-body {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0 0 24px;
    flex-grow: 1;
  }
  .why-proof {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-3);
    border-top: 1px solid var(--border-1);
    padding-top: 14px;
    line-height: 1.55;
    font-style: italic;
  }
  @media (max-width: 860px) {
    .why-grid { grid-template-columns: 1fr; }
  }
</style>
