---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import StatsStrip from "../components/StatsStrip.astro";
import Problem from "../components/Problem.astro";
import Services from "../components/Services.astro";
import WhyMe from "../components/WhyMe.astro";
import HowItWorks from "../components/HowItWorks.astro";
import FAQ from "../components/FAQ.astro";
import CTALast from "../components/CTALast.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <StatsStrip />
    <Problem />
    <Services />
    <WhyMe />
    <HowItWorks />
    <FAQ />
    <CTALast />
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  // Browser language redirect — only on first visit, only for root EN page
  (function () {
    try {
      var REDIRECTED_KEY = "ag_lang_redirect_done";
      if (sessionStorage.getItem(REDIRECTED_KEY)) return;
      var lang = (navigator.language || "en").toLowerCase();
      if (lang.indexOf("uk") === 0) {
        sessionStorage.setItem(REDIRECTED_KEY, "1");
        window.location.replace("/uk/");
      }
    } catch (e) {
      /* ignore */
    }
  })();
</script>
