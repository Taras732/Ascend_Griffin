---
import PostLayout from "../../layouts/PostLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  // Drafts ARE generated (accessible via direct URL) but hidden from /blog/ index + noindex'ed
  const posts = await getCollection("blog", ({ data }) => data.lang === "en");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/^en\//, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

let seriesPrev: { slug: string; title: string; draft: boolean } | undefined;
let seriesNext: { slug: string; title: string; draft: boolean } | undefined;

if (post.data.series) {
  const allInSeries = await getCollection("blog", ({ data }) =>
    data.series === post.data.series && data.lang === "en"
  );
  allInSeries.sort((a, b) => (a.data.seriesOrder ?? 999) - (b.data.seriesOrder ?? 999));
  const idx = allInSeries.findIndex((p) => p.id === post.id);
  if (idx > 0) {
    const prev = allInSeries[idx - 1];
    seriesPrev = {
      slug: `/blog/${prev.id.replace(/^en\//, "")}/`,
      title: prev.data.title,
      draft: !!prev.data.draft,
    };
  }
  if (idx >= 0 && idx < allInSeries.length - 1) {
    const next = allInSeries[idx + 1];
    seriesNext = {
      slug: `/blog/${next.id.replace(/^en\//, "")}/`,
      title: next.data.title,
      draft: !!next.data.draft,
    };
  }
}
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  lang="en"
  tags={post.data.tags}
  ogImage={post.data.ogImage}
  readingTime={post.data.readingTime}
  headings={headings}
  draft={post.data.draft}
  seriesPrev={seriesPrev}
  seriesNext={seriesNext}
>
  <Content />
</PostLayout>
