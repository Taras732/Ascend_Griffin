---
import { site } from "../data/site";

const isUk = Astro.currentLocale === "uk";
const homeHref = isUk ? "/uk/" : "/";

// Switch language while preserving the current page path
// /uk/about/  → /about/    (drop /uk prefix)
// /about/     → /uk/about/ (add /uk prefix)
// /uk/        → /          (root)
// /           → /uk/       (root)
const pathname = Astro.url.pathname || "/";
const altLangHref = isUk
  ? pathname.replace(/^\/uk(\/|$)/, "/") || "/"
  : ("/uk" + pathname).replace(/\/$/, "/");
const altLangLabel = isUk ? "EN" : "UA";

const labels = isUk
  ? {
      about: "Про мене",
      practice: "Практика",
      practiceOverview: "Огляд",
      audit: "Аудит",
      discovery: "Discovery",
      recovery: "Порятунок",
      cases: "Кейси",
      howIWork: "Як я працюю",
      blog: "Блог",
      contact: "Контакти",
      cta: "Обговорити проєкт",
      menu: "Меню",
      altLangAria: `Switch to English`,
    }
  : {
      about: "About",
      practice: "Practice",
      practiceOverview: "Overview",
      audit: "Audit",
      discovery: "Discovery",
      recovery: "Recovery",
      cases: "Cases",
      howIWork: "How I work",
      blog: "Blog",
      contact: "Contact",
      cta: "Discuss your project",
      menu: "Menu",
      altLangAria: `Switch to Ukrainian`,
    };

const prefix = isUk ? "/uk" : "";
const links = {
  about: `${prefix}/about/`,
  practice: `${prefix}/practices/`,
  audit: `${prefix}/ai-readiness-audit/`,
  discovery: `${prefix}/idea-translator/`,
  recovery: `${prefix}/project-rescue/`,
  cases: `${prefix}/case-studies/`,
  howIWork: `${prefix}/how-i-work/`,
  blog: `${prefix}/blog/`,
  contact: `${prefix}/contact/`,
};
---

<nav class="site-nav" aria-label="Primary">
  <div class="site-container nav-inner">
    <a href={homeHref} class="nav-brand" aria-label={`${site.name} — home`}>
      <span class="nav-brand-mark" role="img" aria-label="Ascend Griffin"></span>
      <span class="nav-brand-name">{site.name}</span>
    </a>

    <button class="nav-toggle" aria-label={labels.menu} aria-controls="nav-menu" aria-expanded="false">
      {labels.menu}
    </button>

    <div class="nav-menu" id="nav-menu">
      <ul class="nav-links">
        <li><a href={links.about}>{labels.about}</a></li>

        <li class="nav-dropdown">
          <button
            type="button"
            class="nav-dropdown-trigger"
            aria-expanded="false"
            aria-controls="nav-practice-menu"
          >
            {labels.practice}
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2.5 4.5L6 8l3.5-3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
          <ul class="nav-dropdown-menu" id="nav-practice-menu" role="menu">
            <li role="none"><a role="menuitem" href={links.practice}>{labels.practiceOverview}</a></li>
            <li role="none"><a role="menuitem" href={links.audit}>{labels.audit}</a></li>
            <li role="none"><a role="menuitem" href={links.discovery}>{labels.discovery}</a></li>
            <li role="none"><a role="menuitem" href={links.recovery}>{labels.recovery}</a></li>
            <li role="none"><a role="menuitem" href={links.cases}>{labels.cases}</a></li>
          </ul>
        </li>

        <li><a href={links.howIWork}>{labels.howIWork}</a></li>
        <li><a href={links.blog}>{labels.blog}</a></li>
        <li><a href={links.contact}>{labels.contact}</a></li>
      </ul>

      <div class="nav-actions">
        <a href={altLangHref} class="nav-lang" aria-label={labels.altLangAria}>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
            <path d="M2 12h20" />
          </svg>
          <span>{altLangLabel}</span>
        </a>
        <a href="#book" data-modal="booking" data-subject="discovery-call" data-source="nav" class="nav-cta">{labels.cta}</a>
      </div>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-0);
    border-bottom: 1px solid var(--border-1);
  }
  .nav-inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 16px;
    padding: 14px var(--gutter);
    max-width: var(--container);
    margin: 0 auto;
  }
  @media (max-width: 860px) { .nav-inner { display: flex; justify-content: space-between; align-items: center; } }
  @media (max-width: 720px) { .nav-inner { padding: 14px var(--gutter-sm); } }
  /* nav-menu is transparent to the grid on desktop → its children become grid cells */
  .nav-menu { display: contents; }
  .nav-brand { display: flex; align-items: center; gap: 12px; text-decoration: none; color: var(--text-1); justify-self: start; }
  .nav-actions { display: flex; align-items: center; gap: 12px; justify-self: end; }
  .nav-brand-mark {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background-image: url("/logo/ascend-griffin-full.png");
    background-repeat: no-repeat;
    background-color: #16140F;
    background-size: 76px;
    background-position: -20px -12px;
    box-shadow: 0 0 0 1px var(--accent-border), 0 2px 10px rgba(212, 175, 55, 0.15);
    transition: transform var(--dur-fast) var(--ease), box-shadow var(--dur-fast) var(--ease);
  }
  .nav-brand:hover .nav-brand-mark {
    transform: scale(1.05);
    box-shadow: 0 0 0 1px var(--accent), 0 4px 16px rgba(212, 175, 55, 0.3);
  }
  .nav-brand-name { font-family: var(--font-display); font-size: 17px; font-weight: 700; letter-spacing: -0.015em; }
  .nav-links {
    list-style: none; margin: 0; padding: 0;
    display: flex; align-items: center; gap: 30px;
    justify-self: center;
  }
  .nav-links > li { display: inline-flex; align-items: center; }
  .nav-links > li > a,
  .nav-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    height: 36px;
    line-height: 1;
    font-family: var(--font-mono);
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-2);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
    background: transparent;
    border: 0;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font-weight: 500;
  }
  .nav-links > li > a:hover,
  .nav-dropdown-trigger:hover {
    color: var(--editorial);
  }

  /* Dropdown */
  .nav-dropdown { position: relative; }
  .nav-dropdown-trigger {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .nav-dropdown-trigger svg {
    transition: transform var(--dur-fast) var(--ease);
  }
  .nav-dropdown.is-open .nav-dropdown-trigger svg {
    transform: rotate(180deg);
  }
  .nav-dropdown-menu {
    position: absolute;
    top: calc(100% + 14px);
    left: -16px;
    min-width: 220px;
    background: var(--bg-0);
    border: 1px solid var(--border-2);
    border-radius: 4px;
    box-shadow: var(--shadow-lg);
    padding: 8px 0;
    list-style: none;
    margin: 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity var(--dur-fast) var(--ease), transform var(--dur-fast) var(--ease), visibility var(--dur-fast);
  }
  .nav-dropdown.is-open .nav-dropdown-menu,
  .nav-dropdown:hover .nav-dropdown-menu,
  .nav-dropdown:focus-within .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .nav-dropdown-menu li { margin: 0; }
  .nav-dropdown-menu a {
    display: block;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-1);
    text-decoration: none;
    letter-spacing: 0;
    text-transform: none;
    line-height: 1.4;
    font-weight: 500;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .nav-dropdown-menu a:hover { background: var(--bg-1); color: var(--accent-pressed); }
  .nav-dropdown-soon span {
    display: block;
    padding: 10px 18px;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-4);
    font-style: italic;
    line-height: 1.4;
    cursor: default;
  }

  /* Language toggle — compact icon + 2-letter code, no underline */
  .nav-lang {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 8px;
    border-radius: 6px;
    color: var(--text-3) !important;
    text-decoration: none !important;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    transition: color var(--dur-fast) var(--ease), background var(--dur-fast) var(--ease);
  }
  .nav-lang svg { color: currentColor; flex-shrink: 0; width: 15px; height: 15px; opacity: 0.9; }
  .nav-lang:hover { color: var(--editorial) !important; background: var(--accent-subtle); }

  /* CTA — solid gold pill, no arrow, no underline */
  .nav-cta {
    background: var(--accent);
    color: var(--accent-ink) !important;
    text-decoration: none !important;
    padding: 9px 18px !important;
    height: auto !important;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 11.5px !important;
    font-weight: 700 !important;
    letter-spacing: 0.06em !important;
    box-shadow: 0 2px 10px rgba(201, 168, 106, 0.18);
    white-space: nowrap;
  }
  .nav-cta:hover { background: var(--accent-hover); color: var(--accent-ink) !important; transform: translateY(-1px); }

  /* Toggle */
  .nav-toggle {
    display: none;
    background: transparent;
    border: 1px solid var(--border-2);
    padding: 6px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-1);
    cursor: pointer;
    border-radius: 2px;
  }

  /* Mobile */
  @media (max-width: 860px) {
    .nav-menu { display: none; }
    .nav-toggle { display: block; }
    .nav-menu.open {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-0);
      padding: 20px var(--gutter-sm) 24px;
      border-bottom: 1px solid var(--border-1);
      align-items: stretch;
      gap: 18px;
      max-height: calc(100vh - 64px);
      overflow-y: auto;
      z-index: 90;
    }
    .nav-menu.open .nav-links {
      flex-direction: column;
      align-items: center;
      gap: 18px;
      justify-self: stretch;
    }
    .nav-menu.open .nav-links > li { display: flex; justify-content: center; width: 100%; }
    .nav-menu.open .nav-links > li > a,
    .nav-menu.open .nav-dropdown-trigger { height: auto; font-size: 14px; justify-content: center; }
    .nav-menu.open .nav-dropdown { flex-direction: column; align-items: center; text-align: center; }
    .nav-menu.open .nav-actions {
      flex-direction: column;
      align-items: center;
      gap: 12px;
      justify-self: stretch;
      padding-top: 16px;
      margin-top: 4px;
      border-top: 1px solid var(--border-1);
    }
    .nav-menu.open .nav-lang,
    .nav-menu.open .nav-cta { justify-content: center; text-align: center; }
    .nav-menu.open .nav-cta { padding: 12px 24px !important; font-size: 12.5px !important; }
    .nav-dropdown-menu {
      position: static;
      opacity: 1;
      visibility: visible;
      transform: none;
      box-shadow: none;
      border: 0;
      border-left: 2px solid var(--border-2);
      border-radius: 0;
      padding: 4px 0 4px 12px;
      margin-top: 8px;
      display: none;
    }
    .nav-dropdown.is-open .nav-dropdown-menu { display: block; }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const links = document.getElementById("nav-menu");
  if (toggle && links) {
    toggle.addEventListener("click", () => {
      const open = links.classList.toggle("open");
      toggle.setAttribute("aria-expanded", String(open));
    });
    links.querySelectorAll<HTMLAnchorElement>("a:not(.nav-dropdown-trigger)").forEach((a) => {
      a.addEventListener("click", () => {
        links.classList.remove("open");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }

  // Dropdown click behavior (mobile + accessibility)
  document.querySelectorAll<HTMLElement>(".nav-dropdown").forEach((dd) => {
    const trigger = dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger");
    if (!trigger) return;
    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      const isOpen = dd.classList.toggle("is-open");
      trigger.setAttribute("aria-expanded", String(isOpen));
    });
  });

  // Set lang-redirect flag BEFORE navigation so root-level auto-redirect script
  // doesn't override an explicit user choice. Fixes "first click doesn't work" bug.
  document.querySelectorAll<HTMLAnchorElement>(".nav-lang").forEach((link) => {
    link.addEventListener("click", () => {
      try { sessionStorage.setItem("ag_lang_redirect_done", "1"); } catch (e) { /* ignore */ }
    });
  });


  // Close dropdowns on outside click + Escape
  document.addEventListener("click", (e) => {
    document.querySelectorAll<HTMLElement>(".nav-dropdown.is-open").forEach((dd) => {
      if (!dd.contains(e.target as Node)) {
        dd.classList.remove("is-open");
        dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger")?.setAttribute("aria-expanded", "false");
      }
    });
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      document.querySelectorAll<HTMLElement>(".nav-dropdown.is-open").forEach((dd) => {
        dd.classList.remove("is-open");
        dd.querySelector<HTMLButtonElement>(".nav-dropdown-trigger")?.setAttribute("aria-expanded", "false");
      });
    }
  });
</script>
