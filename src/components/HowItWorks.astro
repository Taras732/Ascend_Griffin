---
import { t } from "../i18n/translations";
const tr = t(Astro.currentLocale);
---

<section class="section how-section" id="how">
  <div class="site-container">
    <div class="section-head">
      <div class="section-num">{tr.howSection.num}</div>
      <div class="section-head-body">
        <h2 set:html={tr.howSection.h2Html} />
        <p class="lede">
          {tr.howSection.lede}
        </p>
      </div>
    </div>

    <ol class="how-timeline">
      {tr.steps.map((s) => (
        <li class="how-step">
          <span class="how-num">{s.num}</span>
          <h4>{s.title}</h4>
          <p class="how-tagline">{s.tagline}</p>
          <span class="how-duration">{s.duration}</span>
          <p class="how-body">{s.body}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
  }
  .how-step {
    padding: 0 24px 8px 0;
    position: relative;
  }
  .how-step::before {
    content: "";
    position: absolute;
    top: 14px;
    left: 44px;
    right: 0;
    height: 1px;
    background: var(--border-2);
    z-index: 0;
  }
  .how-step:last-child::before { display: none; }
  .how-num {
    display: inline-block;
    background: var(--bg-0);
    padding-right: 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--accent-pressed);
    font-weight: 600;
    position: relative;
    z-index: 1;
    margin-bottom: 20px;
    font-variant-numeric: tabular-nums;
  }
  .how-step h4 {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--text-1);
    margin: 0 0 10px;
  }
  .how-tagline {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--accent-pressed);
    margin: 0 0 12px;
    letter-spacing: -0.005em;
  }
  .how-duration {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-3);
    margin-bottom: 14px;
    display: block;
  }
  .how-body {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
    margin: 0;
  }
  @media (max-width: 960px) {
    .how-timeline { grid-template-columns: 1fr; gap: 28px; }
    .how-step { padding: 0 0 24px; border-bottom: 1px solid var(--border-1); }
    .how-step::before { display: none; }
    .how-step:last-child { border-bottom: 0; padding-bottom: 0; }
  }
</style>
