---
interface Props {
  service?: "audit" | "discovery" | "rescue" | "support";
}

const { service = "discovery" } = Astro.props;
const isUk = Astro.currentLocale === "uk";

const copy = isUk
  ? {
      eyebrow: "Наступний крок",
      h: "Discovery Call — 30 хвилин.",
      cta: "Записатися на Discovery Call",
    }
  : {
      eyebrow: "Next step",
      h: "Discovery Call — 30 minutes.",
      cta: "Book Discovery Call",
    };
---

<section class="founding-cta">
  <div class="content-shell">
    <div class="founding-card">
      <p class="founding-eyebrow">{copy.eyebrow}</p>
      <h2 class="founding-h">{copy.h}</h2>
      <a
        href="#book"
        class="founding-btn"
        data-modal="booking"
        data-subject={service === "audit" ? "audit" : service === "discovery" ? "discovery" : service === "support" ? "support" : "discovery-call"}
        data-source={`founding-cta-${service}`}
      >
        {copy.cta} →
      </a>
    </div>
  </div>
</section>

<style>
  .founding-cta { padding: 56px 0 80px; }
  .founding-card {
    background:
      linear-gradient(rgba(9, 11, 14, 0.84), rgba(9, 11, 14, 0.92)),
      var(--bg-ink) url('/img/cta.webp') center/cover no-repeat;
    color: var(--text-on-ink);
    padding: 48px 48px;
    border-radius: 12px; /* Smooth rounded card */
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  @media (max-width: 720px) { .founding-card { padding: 36px 24px; } }
  .founding-card::before {
    content: "";
    position: absolute; top: -50%; right: -20%;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(184,135,58,.08), transparent 60%);
    pointer-events: none;
  }
  .founding-eyebrow {
    font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.14em;
    text-transform: uppercase; color: var(--accent); margin: 0 0 16px;
    font-weight: 600; position: relative;
  }
  .founding-h {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 36px);
    color: var(--text-on-ink);
    line-height: 1.2; letter-spacing: -0.015em;
    margin: 0 0 28px; font-weight: 700; position: relative;
  }
  .founding-btn {
    display: inline-block;
    background: var(--accent); color: var(--accent-ink);
    padding: 16px 32px; text-decoration: none;
    font-weight: 600; border-radius: 4px; /* Balanced button rounding */
    font-size: 15px; letter-spacing: 0.02em;
    transition: background var(--dur-fast) var(--ease);
    position: relative;
  }
  .founding-btn:hover { background: var(--accent-hover); }
</style>
