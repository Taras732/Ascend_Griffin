---
interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 32, height = 32, class: className = "" } = Astro.props;
// Unique gradient id per instance (avoids collisions when logo appears multiple times)
const gid = "ag-gold-" + Math.random().toString(36).slice(2, 8);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 100 100"
  fill="none"
  width={width}
  height={height}
  class={className}
  role="img"
  aria-label="Ascend Griffin"
>
  <defs>
    <linearGradient id={gid} x1="20" y1="14" x2="86" y2="92" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#E7C66A" />
      <stop offset="45%" stop-color="#D4AF37" />
      <stop offset="100%" stop-color="#9A7B1C" />
    </linearGradient>
  </defs>

  <!-- Rising griffin: tall swept wing + sharp eagle head facing right + tail clin -->
  <g fill={`url(#${gid})`} stroke={`url(#${gid})`} stroke-width="0.5" stroke-linejoin="round">
    <!-- Tall swept wing (up-right) with feather notches on the trailing edge -->
    <path d="M52 56
             L22 34
             L30 34
             L24 22
             L32 24
             L29 12
             L37 17
             L38 7
             L45 18
             L50 15
             Z" />
    <!-- Slender neck + sharp eagle head facing right with hooked beak -->
    <path d="M52 56
             C52 48, 55 44, 60 43
             L63 40
             C65 38, 68 39, 69 42
             L78 47
             C79 48, 78 50, 76 49
             L70 47
             L68 50
             C63 52, 57 52, 52 56
             Z" />
    <!-- Body + pointed tail sweeping down -->
    <path d="M52 56
             L48 74
             L53 88
             L60 73
             L56 57
             Z" />
  </g>
  <!-- Eye (negative space) -->
  <circle cx="64.5" cy="44" r="1.3" fill="var(--bg-0, #0D0D0B)" />
</svg>
